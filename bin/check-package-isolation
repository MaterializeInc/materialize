# check-package-isolation — runs `cargo check --all-targets` for each
# workspace package in isolation.
#
# Buildkite parallelism: if BUILDKITE_PARALLEL_JOB_COUNT is set, this script
# only checks the slice of packages assigned to its BUILDKITE_PARALLEL_JOB
# index (round-robin partitioning).

set -uo pipefail

cd "$(dirname "$0")/.." || exit

. misc/shlib/shlib.bash

mapfile -t packages < <(
    cargo metadata --no-deps --format-version=1 \
        | python3 -c 'import json, sys; [print(p["name"]) for p in json.load(sys.stdin)["packages"]]' \
        | sort
)

shard_count="${BUILDKITE_PARALLEL_JOB_COUNT:-1}"
shard_index="${BUILDKITE_PARALLEL_JOB:-0}"

failed=()
checked=0
for i in "${!packages[@]}"; do
    if (( i % shard_count != shard_index )); then
        continue
    fi
    pkg="${packages[$i]}"
    checked=$((checked + 1))
    echo "--- :rust: cargo check --all-targets -p $pkg"
    if ! cargo check --all-targets --package "$pkg"; then
        failed+=("$pkg")
    fi
done

echo
echo "Checked $checked package(s) on shard $shard_index/$shard_count."
if (( ${#failed[@]} > 0 )); then
    echo "FAILED: ${#failed[@]} package(s) failed isolated check:"
    printf '  - %s\n' "${failed[@]}"
    exit 1
fi
echo "All packages on this shard compiled in isolation."
