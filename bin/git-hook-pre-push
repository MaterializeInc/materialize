# git-hook-pre-push — verify workspace-hack is up-to-date before pushing.
#
# Install:
#   ln -sf ../../bin/git-hook-pre-push .git/hooks/pre-push

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# Skip if no Cargo.toml files were changed in the commits being pushed.
# The pre-push hook receives lines of: <local ref> <local sha> <remote ref> <remote sha>
# on stdin. We check if any Cargo.toml changed between the remote sha and local sha.
cargo_changed=false
while read -r _ local_sha _ remote_sha; do
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        # New branch — compare against main.
        remote_sha="$(git merge-base HEAD origin/main 2>/dev/null || echo HEAD~1)"
    fi
    if git diff --name-only "$remote_sha" "$local_sha" 2>/dev/null | grep -q 'Cargo\.toml'; then
        cargo_changed=true
        break
    fi
done

if [ "$cargo_changed" = false ]; then
    exit 0
fi

if ! command -v cargo-hakari &>/dev/null; then
    # If hakari isn't installed, skip — CI will catch it.
    exit 0
fi

if ! cargo hakari generate --diff >/dev/null 2>&1; then
    echo >&2 ""
    echo >&2 "pre-push: src/workspace-hack/Cargo.toml is out of date."
    echo >&2 ""
    echo >&2 "  Run:  cargo hakari generate"
    echo >&2 "  Then: git add src/workspace-hack/Cargo.toml Cargo.lock && git commit --amend --no-edit"
    echo >&2 ""
    exit 1
fi

if ! cargo hakari manage-deps --dry-run >/dev/null 2>&1; then
    echo >&2 ""
    echo >&2 "pre-push: workspace-hack dependency declarations are out of date."
    echo >&2 ""
    echo >&2 "  Run:  cargo hakari manage-deps"
    echo >&2 "  Then: git add . && git commit --amend --no-edit"
    echo >&2 ""
    exit 1
fi
