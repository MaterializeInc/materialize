ions":{"readOnlyHint":true,"destructiveHint":false,"idempotentHint":true,"openWorldHint":false}}]}}

# Null id is treated as a notification by serde (Option<Value> deserializes null as None).
mcp-agents
{"jsonrpc":"2.0","id":null,"method":"tools/list"}
----
200 OK
