# =============================================================================
# Initialize
# =============================================================================

# Standard MCP initialize handshake for developer endpoint.
mcp-developer
{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-11-25","capabilities":{},"clientInfo":{"name":"test-client","version":"1.0.0"}}}
----
200 OK
{"jsonrpc":"2.0","id":1,"result":{"protocolVersion":"2025-11-25","capabilities":{"tools":{}},"serverInfo":{"name":"materialize-mcp-developer","version":"<VERSION>"},"instructions":"You are connected to the Materialize developer MCP server. You have read-only access to system catalog tables (mz_*, pg_catalog, information_schema) for troubleshooting and observability.\n\nIMPORTANT: Before writing queries, discover table schemas using the mz_ontology tables:\n- mz_internal.mz_ontology_entity_types: what catalog entities exist and which tables they map to\n- mz_internal.mz_ontology_link_types: relationships between entities (foreign keys, metrics, etc.)\n- mz_internal.mz_ontology_properties: column names, types, and descriptions for each entity\n- mz_internal.mz_ontology_semantic_types: typed ID domains (CatalogItemId, ReplicaId, etc.)\n\nUse these to find the correct tables, join paths, and column names instead of guessing.\n\nKey rules:\n- mz_source_statuses and mz_sink_statuses use `last_status_change_at` (NOT `updated_at`)\n- mz_cluster_replica_utilization only has `replica_id` — JOIN with mz_cluster_replicas and mz_clusters to get names\n- Do NOT query mz_introspection.mz_dataflow_arrangement_sizes — it is cluster-scoped and has uint8/text type mismatches\n- Use SHOW COLUMNS FROM <table> to verify column names if unsure"}}

# =============================================================================
# Tools List
# =============================================================================

# Developer should only expose query_system_catalog.
mcp-developer
{"jsonrpc":"2.0","id":2,"method":"tools/list"}
----
200 OK
{"jsonrpc":"2.0","id":2,"result":{"tools":[{"name":"query_system_catalog","title":"Query System Catalog","description":"Query Materialize system catalog tables for troubleshooting and observability. Only mz_*, pg_catalog, and information_schema tables are accessible. Use the mz_internal.mz_ontology_* tables to discover tables, columns, and join paths before writing queries. Response limit: 1 MB.","inputSchema":{"type":"object","properties":{"sql_query":{"type":"string","description":"PostgreSQL-compatible SELECT, SHOW, or EXPLAIN query referencing mz_* system catalog tables"}},"required":["sql_query"]},"annotations":{"readOnlyHint":true,"destructiveHint":false,"idempotentHint":true,"openWorldHint":false}}]}}

# =============================================================================
# query_system_catalog - valid system catalog queries
# =============================================================================

# Query mz_databases for the default database should work and return predictable result.
mcp-developer
{"jsonrpc":"2.0","id":10,"method":"tools/call","params":{"name":"query_system_catalog","arguments":{"sql_query":"SELECT name FROM mz_databases WHERE name = 'materialize'"}}}
----
200 OK
{"jsonrpc":"2.0","id":10,"result":{"content":[{"type":"text","text":"[\n  [\n    \"materialize\"\n  ]\n]"}],"isError":false}}

# Query with qualified schema should work.
mcp-developer
{"jsonrpc":"2.0","id":11,"method":"tools/call","params":{"name":"query_system_catalog","arguments":{"sql_query":"SELECT name FROM mz_catalog.mz_databases WHERE name = 'materialize'"}}}
----
200 OK
{"jsonrpc":"2.0","id":11,"result":{"content":[{"type":"text","text":"[\n  [\n    \"materialize\"\n  ]\n]"}],"isError":false}}

# =============================================================================
# query_system_catalog - pg_catalog and information_schema
# =============================================================================

# pg_catalog should be accessible.
mcp-developer
{"jsonrpc":"2.0","id":12,"method":"tools/call","params":{"name":"query_system_catalog","arguments":{"sql_query":"SELECT typname FROM pg_catalog.pg_type WHERE typname = 'bool'"}}}
----
200 OK
{"jsonrpc":"2.0","id":12,"result":{"content":[{"type":"text","text":"[\n  [\n    \"bool\"\n  ]\n]"}],"isError":false}}

# information_schema should be accessible.
mcp-developer
{"jsonrpc":"2.0","id":13,"method":"tools/call","params":{"name":"query_system_catalog","arguments":{"sql_query":"SELECT table_schema FROM information_schema.tables WHERE table_name = 'mz_databases' AND table_schema = 'mz_catalog' LIMIT 1"}}}
----
200 OK
{"jsonrpc":"2.0","id":13,"result":{"content":[{"type":"text","text":"[\n  [\n    \"mz_catalog\"\n  ]\n]"}],"isError":false}}

# =============================================================================
# query_system_catalog - non-system tables rejected
# =============================================================================

# Querying a non-system table should be rejected.
mcp-developer
{"jsonrpc":"2.0","id":20,"method":"tools/call","params":{"name":"query_system_catalog","arguments":{"sql_query":"SELECT * FROM user_table"}}}
----
200 OK
{"jsonrpc":"2.0","id":20,"error":{"code":-32602,"message":"Query validation failed: Query references non-system tables: user_table. Only system catalog tables (mz_*, pg_catalog, information_schema) are allowed.","data":{"error_type":"ValidationError"}}}

# Querying a non-system schema should be rejected.
mcp-developer
{"jsonrpc":"2.0","id":21,"method":"tools/call","params":{"name":"query_system_catalog","arguments":{"sql_query":"SELECT * FROM public.my_view"}}}
----
200 OK
{"jsonrpc":"2.0","id":21,"error":{"code":-32602,"message":"Query validation failed: Query references non-system tables: public.my_view. Only system catalog tables (mz_*, pg_catalog, information_schema) are allowed.","data":{"error_type":"ValidationError"}}}

# =============================================================================
# query_system_catalog - DDL rejected
# =============================================================================

# DDL on system tables should still be rejected (read-only validation runs first).
mcp-developer
{"jsonrpc":"2.0","id":22,"method":"tools/call","params":{"name":"query_system_catalog","arguments":{"sql_query":"DROP TABLE mz_tables"}}}
----
200 OK
{"jsonrpc":"2.0","id":22,"error":{"code":-32602,"message":"Query validation failed: Only SELECT, SHOW, and EXPLAIN statements are allowed","data":{"error_type":"ValidationError"}}}

# =============================================================================
# query_system_catalog - multi-statement rejected
# =============================================================================

mcp-developer
{"jsonrpc":"2.0","id":23,"method":"tools/call","params":{"name":"query_system_catalog","arguments":{"sql_query":"SELECT 1; SELECT * FROM mz_tables"}}}
----
200 OK
{"jsonrpc":"2.0","id":23,"error":{"code":-32602,"message":"Query validation failed: Only one query allowed at a time. Found 2 statements.","data":{"error_type":"ValidationError"}}}

# =============================================================================
# query_system_catalog - empty query
# =============================================================================

mcp-developer
{"jsonrpc":"2.0","id":24,"method":"tools/call","params":{"name":"query_system_catalog","arguments":{"sql_query":""}}}
----
200 OK
{"jsonrpc":"2.0","id":24,"error":{"code":-32602,"message":"Query validation failed: Empty query","data":{"error_type":"ValidationError"}}}

# =============================================================================
# query_system_catalog - must reference at least one system table
# =============================================================================

# A query with no table reference should be rejected.
mcp-developer
{"jsonrpc":"2.0","id":25,"method":"tools/call","params":{"name":"query_system_catalog","arguments":{"sql_query":"SELECT 1"}}}
----
200 OK
{"jsonrpc":"2.0","id":25,"error":{"code":-32602,"message":"Query validation failed: Query must reference at least one system catalog table","data":{"error_type":"ValidationError"}}}

