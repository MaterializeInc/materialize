{"jsonrpc":"2.0","id":32,"error":{"code":-32602,"message":"Tool not found: query is not available on observatory endpoint","data":{"error_type":"ToolNotFound"}}}

# Calling get_data_product_details on observatory endpoint should fail.
mcp-observatory
{"jsonrpc":"2.0","id":33,"method":"tools/call","params":{"name":"get_data_product_details","arguments":{"name":"some_product"}}}
