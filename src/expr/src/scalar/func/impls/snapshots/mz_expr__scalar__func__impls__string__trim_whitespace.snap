pub struct TrimWhitespace;
impl crate::func::EagerUnaryFunc for TrimWhitespace {
    type Input<'a> = &'a str;
    type Output<'a> = &'a str;
    fn call<'a>(&self, a: Self::Input<'a>) -> Self::Output<'a> {
        trim_whitespace(a)
