parse-statement
CREATE BRANCH nightly FROM SCHEMA public
----
CREATE BRANCH nightly FROM SCHEMA public
=>
CreateBranch(CreateBranchStatement { name: Ident("nightly"), source_schema: UnresolvedSchemaName([Ident("public")]) })

parse-statement
CREATE BRANCH b FROM SCHEMA db.s
----
CREATE BRANCH b FROM SCHEMA db.s
=>
CreateBranch(CreateBranchStatement { name: Ident("b"), source_schema: UnresolvedSchemaName([Ident("db"), Ident("s")]) })

parse-statement
DROP BRANCH nightly
----
DROP BRANCH nightly
=>
DropBranch(DropBranchStatement { if_exists: false, name: Ident("nightly") })

parse-statement
DROP BRANCH IF EXISTS nightly
----
DROP BRANCH IF EXISTS nightly
=>
DropBranch(DropBranchStatement { if_exists: true, name: Ident("nightly") })

parse-statement
SHOW BRANCHES
----
SHOW BRANCHES
=>
ShowBranches(ShowBranchesStatement)

parse-statement
SHOW BRANCH STATUS nightly
----
SHOW BRANCH STATUS nightly
=>
ShowBranchStatus(ShowBranchStatusStatement { name: Ident("nightly") })

# `FROM BRANCH` and `FROM DATABASE` are intentionally not recognized in the
# MVP: only `FROM SCHEMA` is parsed. Confirm the parser rejects them.

parse-statement
CREATE BRANCH b FROM BRANCH p
----
error: Expected SCHEMA, found BRANCH
CREATE BRANCH b FROM BRANCH p
                     ^

parse-statement
CREATE BRANCH b FROM DATABASE p
----
error: Expected SCHEMA, found DATABASE
CREATE BRANCH b FROM DATABASE p
                     ^
