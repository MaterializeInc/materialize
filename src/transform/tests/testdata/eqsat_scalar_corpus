# eqsat scalar differential corpus (slice 1 seed).
# Format: `expr` line, `types` line (comma-separated ReprScalarType names), blank separator.
# Slice 1 covers not_not; ties/could_error/type axes are seeded here and grown per slice.
expr: not(not(#0))
types: bool

expr: not(not(not(#0)))
types: bool

expr: #0
types: bool

# --- slice 2: variadic (and/or single, de Morgan) ---
# and_single / or_single
expr: and(#0)
types: bool

expr: or(#0)
types: bool

# de Morgan, both directions, >2 operands (multi-operand variadic parity)
expr: not(and(#0, #1, #2))
types: bool,bool,bool

expr: not(or(#0, #1, #2, #3))
types: bool,bool,bool,bool

# de Morgan feeding single-collapse: Not(And(#0)) -> Or(Not #0) -> Not #0
expr: not(and(#0))
types: bool

# --- slice 3: If resolution (literal-bool/null fold, could_error gate) ---
# if_true / if_false_or_null: literal-bool and literal-null conditions
# (the `literal` analysis axis). Branches are bare columns so nothing else
# in the old engine's 20-rule set can touch the If.
expr: if(true, #0, #1)
types: bool,bool

expr: if(false, #0, #1)
types: bool,bool

expr: if(null, #0, #1)
types: bool,bool

# if_same_branches, could_error gate POSITIVE: the condition is a bare bool
# column, which cannot error, so the gate permits the collapse.
expr: if(#0, #1, #1)
types: bool,bool

# if_same_branches, could_error gate NEGATIVE control: the condition CAN
# error (integer division, #0 / #1 = 0). Both operands of the division are
# columns, not literals, so the old engine's unported const_fold cannot fold
# the condition out from under this test; only the could_error gate is under
# test. The If must survive unresolved in BOTH engines.
expr: if(#0 / #1 = 0, #2, #2)
types: int64,int64,int64

# --- slice 4: const_fold, and_empty, or_empty ---
# All-literal fold, non-error (the `literal` axis over Unary/Binary/If).
expr: 1 + 2
types:

expr: not(true)
types:

expr: if(true, 1, 2)
types:

# All-literal fold, error-as-data (highest risk): the fold must reproduce
# the runtime error AS a literal in both engines, not panic and not
# silently drop it.
expr: 1 / 0
types:

expr: i64::MAX + 1
types:

# Nested pre-existing error-literal child: the inner div folds to an error
# literal on one saturation round, then the outer add folds on a later
# round, propagating the error through eval's child-error short circuit.
expr: (1 / 0) + 5
types:

# Partial-literal: a Column child blocks const_fold in both engines.
expr: #0 + 1
types: int64

# Empty identities (declarative RHS, distinct from and_single/or_single).
expr: and()
types:

expr: or()
types:

# Interaction with slice-2 and_single: And(#0) collapses via and_single
# (see the and(#0) case above), not and_empty. and() and and(#0) must not
# fight or fail to reach a fixpoint.

# --- slice 5: if_err_cond, null_prop_binary, err_prop_binary, isnull_fold,
# not_binary_negate ---
# if_err_cond: a literal-error condition (`1 / 0`, folded by const_fold)
# folds the whole If to that error. Branches carry distinct types (#0
# non-nullable, #1 nullable), exercising the then.typ.union(els.typ) path.
expr: if(1 / 0, #0, #1)
types: int64,int64

# null_prop_binary: a null-propagating func with a literal-null operand and a
# non-erroring other operand folds to null.
expr: null + #0
types: int64

# err_prop_binary: a literal-error operand with a non-erroring other operand
# folds to that error.
expr: (1 / 0) + #0
types: int64

# isnull_fold: IsNull of a non-nullable, error-free operand folds to false.
# The same shape with #0 typed nullable must not fold.
expr: #0 is null
types: int64

# not_binary_negate (highest risk: negate(f) must choose the correct partner
# from BinaryFunc::negate()'s table): exhaustively tested in the differential
# harness over every negation pair (Eq/NotEq, Lt/Gte, Lte/Gt); representative
# samples of each pair below.
expr: not(#0 = #1)
types: int64,int64

expr: not(#0 < #1)
types: int64,int64

expr: not(#0 <= #1)
types: int64,int64

# --- slice 6a: and_or_short_circuit (and_short_circuit / or_short_circuit) ---
# Positions: leading / middle / trailing false operand, all collapse to false.
expr: and(false, #0, #1)
types: bool,bool

expr: and(#0, false, #1)
types: bool,bool

expr: and(#0, #1, false)
types: bool,bool

# Dual: leading / middle / trailing true operand, all collapse to true.
expr: or(true, #0, #1)
types: bool,bool

expr: or(#0, true, #1)
types: bool,bool

expr: or(#0, #1, true)
types: bool,bool

# 3VL: false dominates a null operand regardless of position.
expr: and(#0, false, null)
types: bool

expr: or(#0, true, null)
types: bool

# E-err envelope: the fold is UNCONDITIONAL, no could_error guard. And
# returns false as soon as it sees a false operand even if another operand
# errors (func/variadic.rs's eval loop discards any accumulated error on the
# early return); both operand orders below must fold to false/true.
expr: and(false, 1 / 0)
types:

expr: and(1 / 0, false)
types:

expr: or(true, 1 / 0)
types:

expr: or(1 / 0, true)
types:

# Interactions: single-operand and duplicate-false operands must not fight
# and_single / and_or_dedup.
expr: and(false)
types:

expr: and(false, false)
types:
