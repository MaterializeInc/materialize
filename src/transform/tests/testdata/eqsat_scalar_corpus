# eqsat scalar differential corpus (slice 1 seed).
# Format: `expr` line, `types` line (comma-separated ReprScalarType names), blank separator.
# Slice 1 covers not_not; ties/could_error/type axes are seeded here and grown per slice.
expr: not(not(#0))
types: bool

expr: not(not(not(#0)))
types: bool

expr: #0
types: bool

# --- slice 2: variadic (and/or single, de Morgan) ---
# and_single / or_single
expr: and(#0)
types: bool

expr: or(#0)
types: bool

# de Morgan, both directions, >2 operands (multi-operand variadic parity)
expr: not(and(#0, #1, #2))
types: bool,bool,bool

expr: not(or(#0, #1, #2, #3))
types: bool,bool,bool,bool

# de Morgan feeding single-collapse: Not(And(#0)) -> Or(Not #0) -> Not #0
expr: not(and(#0))
types: bool

# --- slice 3: If resolution (literal-bool/null fold, could_error gate) ---
# if_true / if_false_or_null: literal-bool and literal-null conditions
# (the `literal` analysis axis). Branches are bare columns so nothing else
# in the old engine's 20-rule set can touch the If.
expr: if(true, #0, #1)
types: bool,bool

expr: if(false, #0, #1)
types: bool,bool

expr: if(null, #0, #1)
types: bool,bool

# if_same_branches, could_error gate POSITIVE: the condition is a bare bool
# column, which cannot error, so the gate permits the collapse.
expr: if(#0, #1, #1)
types: bool,bool

# if_same_branches, could_error gate NEGATIVE control: the condition CAN
# error (integer division, #0 / #1 = 0). Both operands of the division are
# columns, not literals, so the old engine's unported const_fold cannot fold
# the condition out from under this test; only the could_error gate is under
# test. The If must survive unresolved in BOTH engines.
expr: if(#0 / #1 = 0, #2, #2)
types: int64,int64,int64

# --- slice 4: const_fold, and_empty, or_empty ---
# All-literal fold, non-error (the `literal` axis over Unary/Binary/If).
expr: 1 + 2
types:

expr: not(true)
types:

expr: if(true, 1, 2)
types:

# All-literal fold, error-as-data (highest risk): the fold must reproduce
# the runtime error AS a literal in both engines, not panic and not
# silently drop it.
expr: 1 / 0
types:

expr: i64::MAX + 1
types:

# Nested pre-existing error-literal child: the inner div folds to an error
# literal on one saturation round, then the outer add folds on a later
# round, propagating the error through eval's child-error short circuit.
expr: (1 / 0) + 5
types:

# Partial-literal: a Column child blocks const_fold in both engines.
expr: #0 + 1
types: int64

# Empty identities (declarative RHS, distinct from and_single/or_single).
expr: and()
types:

expr: or()
types:

# Interaction with slice-2 and_single: And(#0) collapses via and_single
# (see the and(#0) case above), not and_empty. and() and and(#0) must not
# fight or fail to reach a fixpoint.
