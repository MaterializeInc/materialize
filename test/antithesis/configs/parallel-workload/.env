# PLACEHOLDER — do not edit, do not rely on. CI overwrites this file at
# build time via ci/test/build-antithesis.sh (which calls
# `bin/pyactivate test/antithesis/export-env.py --registry <antithesis-registry>`).
# Committed only so the antithesis-config-<group> mzbuild image can build
# in code review / lint contexts without first running the env script.
# Compose runs with these placeholder refs will fail to pull, which is
# intentional — the failure is the signal that build-antithesis.sh
# didn't run.
MATERIALIZED_IMAGE=placeholder/materialized:replace-via-export-env.py
ANTITHESIS_WORKLOAD_IMAGE=placeholder/antithesis-workload:replace-via-export-env.py
