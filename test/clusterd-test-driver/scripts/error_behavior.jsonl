# error-behavior scenario: each expect_error runs a command that must fail; the
# run passes because the failures are caught (and reported as `caught_error`).
#
# Input validation, caught before reaching clusterd:
# Reference to a schema that was never declared.
{"cmd":"expect_error","command":{"cmd":"write_single_ts","shard":"e","schema":"nope","ts":0,"count":1}}
# Wrong row arity: the sample schema has two columns, the row has one.
{"cmd":"expect_error","command":{"cmd":"write_rows","shard":"e","ts":0,"rows":[[1]]}}
# Wrong value type: text supplied for the bigint column.
{"cmd":"expect_error","command":{"cmd":"write_rows","shard":"e","ts":0,"rows":[["not-an-int","x"]]}}
# Replica behavior: an unscheduled dataflow makes no progress, so awaiting its
# output frontier times out. With a short timeout this is caught, not fatal.
{"cmd":"write_single_ts","shard":"e","ts":0,"count":100}
{"cmd":"define_index","source_id":1000,"index_id":1001,"shard":"e","key":[0],"as_of":0,"upper":1}
{"cmd":"expect_error","command":{"cmd":"await_frontier","id":1001,"ts":1,"timeout_secs":3}}
