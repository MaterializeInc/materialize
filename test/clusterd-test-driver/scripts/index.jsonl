# Reproduce the `index` scenario via the JSON command reader.
# One command per line; `#`/`//` lines and blanks are ignored.
# Run locally: SCENARIO=script SCRIPT=test/clusterd-test-driver/scripts/index.jsonl \
#   bin/pyactivate test/clusterd-test-driver/run-local.py
#
# Load phase: write 5000 rows at ts 0, build an index keyed by column 0, hydrate.
# No `schema` field, so the built-in (bigint, text) sample schema is used.
{"cmd":"write_single_ts","shard":"data","ts":0,"count":5000}
{"cmd":"define_index","source_id":1000,"index_id":1001,"shard":"data","key":[0],"as_of":0,"upper":1}
{"cmd":"schedule","id":1001}
{"cmd":"await_frontier","id":1001,"ts":1}
# Confirm all loaded rows are present.
{"cmd":"peek_count","id":1001,"ts":0}
