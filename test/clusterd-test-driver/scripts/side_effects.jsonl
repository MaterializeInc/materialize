# side-effects scenario: drive AllowCompaction explicitly and confirm the replica
# keeps serving. Write at two timestamps so a peek lands in [since, upper) after
# compaction: ts 0 (5000 rows) and ts 1 (1000 rows, disjoint ids), sealing upper
# to 2.
{"cmd":"write_single_ts","shard":"se","ts":0,"count":5000}
{"cmd":"write_single_ts","shard":"se","ts":1,"start":5000,"count":1000}
{"cmd":"define_index","source_id":1000,"index_id":1001,"shard":"se","key":[0],"as_of":0,"upper":2}
{"cmd":"schedule","id":1001}
{"cmd":"await_frontier","id":1001,"ts":2}
# Advance the read frontier (since) to ts 1: no consumer will read below 1, so the
# replica may compact data under it.
{"cmd":"allow_compaction","id":1001,"frontier":1}
# Peek at ts 1 (>= since, < upper); both batches are visible: 5000 + 1000.
{"cmd":"expect_count","id":1001,"ts":1,"count":6000}
