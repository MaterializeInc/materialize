CommandComplete {"tag":"CREATE TABLE"}
ReadyForQuery {"status":"I"}

send
Query {"query": "COPY t5 (x, y) FROM STDIN WITH (FORMAT CSV)"}
CopyData "1,one\n"
CopyData "2,\"two\"\n"
CopyData "3,\"\"\"three\"\"\"\n"
CopyData "4,\"fo,ur\"\n"
CopyData "5,\"\"\n"
CopyData "6,\n"
