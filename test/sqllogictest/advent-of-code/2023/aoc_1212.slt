          Project (#0, #20, #21) // { arity: 3 }
            Map (((#1{chars} + #4{len}) + 1), (#2{spring} + 1)) // { arity: 22 }
              Join on=(#0{r} = #7 = #14 = #17 AND #1 = #8 = #15 = #18 AND #2 = #9 AND #3 = #10 AND #4 = #11 = #16 = #19 AND #5 = #12 AND #6 = #13) type=delta // { arity: 20 }
                implementation
                  %0:l2 » %1:l3[#0..=#6]UKKKKKKKf » %3:l5[#0..=#2]UKKK » %2[#0..=#2]KKK
                  %1:l3 » %3:l5[#0..=#2]UKKK » %0:l2[#0{r}..=#6]KKKKKKKf » %2[#0..=#2]KKK
