          Project (#0, #5, #2) // { arity: 3 }
            Map ((#1{chars} + 1)) // { arity: 6 }
              Join on=(#0{r} = #3{r} AND #4{pos} = (#1{chars} + 1)) type=differential // { arity: 5 }
                implementation
                  %1:l1[#0{r}, #1{pos}]KKf » %0:l6[#0{r}, (#1{chars} + 1)]KKf
                ArrangeBy keys=[[#0{r}, (#1{chars} + 1)]] // { arity: 3 }
