# An index on a CASE-over-literals expression is matched by a query that
# filters on the same CASE expression, now that CaseLiteral is part of the
# canonical reduce output (index key and query expression reduce identically).

statement ok
CREATE TABLE t (a int)

statement ok
CREATE INDEX t_case_idx ON t (CASE WHEN a = 1 THEN 10 WHEN a = 2 THEN 20 ELSE 0 END)

query T multiline
EXPLAIN OPTIMIZED PLAN WITH(humanized expressions) AS VERBOSE TEXT FOR
SELECT * FROM t WHERE (CASE WHEN a = 1 THEN 10 WHEN a = 2 THEN 20 ELSE 0 END) = 10
----
Explained Query (fast path):
  Project (#1{a})
    ReadIndex on=materialize.public.t t_case_idx=[lookup value=(10)]

Used Indexes:
  - materialize.public.t_case_idx (lookup)

Target cluster: quickstart

