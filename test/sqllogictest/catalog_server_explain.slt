query T multiline
EXPLAIN INDEX "mz_catalog"."mz_recent_storage_usage_ind";
----
mz_catalog.mz_recent_storage_usage_ind:
  →Arrange (#0{object_id})
    →Stream mz_catalog.mz_recent_storage_usage

mz_catalog.mz_recent_storage_usage:
  →With
    cte l0 =
      →Read mz_internal.mz_storage_usage_by_shard
    cte l1 =
      →Differential Join %1[#0] » %0:mz_storage_shards[#1{shard_id}]
        →Arrange (#1{shard_id})
          →Stream mz_internal.mz_storage_shards
        →Temporally-Bucketed Bucketed Hierarchical GroupAggregate (buckets: 268435456 16777216 1048576 65536 4096 256 16)
          Aggregations: max
          Key:
            Project: #0
          →Fused with Child Map/Filter/Project
            Project: #0, #2
              →Read l0
    cte l2 =
      →Union
        →Map/Filter/Project
          Project: #0..=#2
          Map: null
            →Consolidating Union
              →Negate Diffs
                →Fused with Child Map/Filter/Project
                  Project: #0, #1
                    →Read l1
              →Stream mz_internal.mz_storage_shards
        →Stream l1
    cte l3 =
      →Arrange (#1{shard_id}, #2{collection_timestamp})
        →Fused with Child Map/Filter/Project
          Filter: (#2{collection_timestamp}) IS NOT NULL
            →Read l2
    cte l4 =
      →Differential Join %1:l0[#0{shard_id}, #2{collection_timestamp}] » %0:l3[#1{shard_id}, #2{collection_timestamp}]
        →Arranged l3
        →Arrange (#0{shard_id}, #2{collection_timestamp})
          →Stream l0
  →Return
    →Map/Filter/Project
      Project: #0, #2
      Map: numeric_to_uint8(#1)
        →Accumulable GroupAggregate
          Simple aggregates: sum(#1{size_bytes})
          Key:
            Project: #0
          →Union
            →Map/Filter/Project
              Project: #0, #1
              Map: null
                →Consolidating Union
                  →Negate Diffs
                    →Differential Join %1[#0, #1] » %0:l3[#1{shard_id}, #2{collection_timestamp}]
                      →Arranged l3
                      →Distinct GroupAggregate
                        →Fused with Child Map/Filter/Project
                          Project: #1, #2
                            →Read l4
                  →Fused with Child Map/Filter/Project
                    Project: #0
                      →Read l2
            →Fused with Child Map/Filter/Project
              Project: #0, #3
                →Read l4

Source mz_internal.mz_storage_usage_by_shard
  project=(#1..=#3)
  filter=((#1{shard_id}) IS NOT NULL AND (mz_now() <= #4) AND (mz_now() < step_mz_timestamp(#4)))
  map=(timestamp_tz_to_mz_timestamp((#3{collection_timestamp} + 06:00:00)))
Source mz_internal.mz_storage_shards

Target cluster: mz_catalog_server

EOF

