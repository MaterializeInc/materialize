query T multiline
EXPLAIN INDEX "mz_internal"."mz_cluster_replica_history_ind";
----
mz_internal.mz_cluster_replica_history_ind:
  →Arrange (#6{dropped_at})
    →Stream mz_internal.mz_cluster_replica_history

mz_internal.mz_cluster_replica_history:
  →With
    cte l0 =
      →Fused with Child Map/Filter/Project
        Project: #0..=#2, #4
          →Read mz_catalog.mz_audit_events
  →Return
    →Delta Join [%0:mz_audit_events[#1] » %1[#0] » %2[#0]] [%1[#0] » %0:mz_audit_events[#2] » %2[#0]] [%2[#0] » %0:mz_audit_events[#1] » %1[#0]]
      path %0:
        after %1:
          Project: #1, #2, #0, #3..=#5, #8
          Map: case when (#7) IS NULL then null else #6 end
        after %2:
          Project: #2, #0, #5, #4, #3, #1, #6, #9
          Map: case when (#8) IS NULL then null else #7 end
      path %1:
        after %2:
          Project: #2, #0, #5, #4, #3, #1, #6, #9
          Map: case when (#8) IS NULL then null else #7 end
      path %2:
        after %1:
          Project: #0, #2, #5, #4, #3, #1, #9, #6
          Map: case when (#8) IS NULL then null else #7 end
      →Arrange (#1) (#2)
        →Fused with Child Map/Filter/Project
          Project: #3, #6, #4, #7, #8, #5
          Filter: (#0{event_type} = "create") AND (#1{object_type} = "cluster-replica") AND (#4) IS NOT NULL AND NOT(like["s%"](#5))
          Map: (#2{details} ->> "cluster_id"), (#2{details} ->> "logical_size"), (#2{details} ->> "replica_name"), (#2{details} ->> "cluster_name")
            →Read mz_catalog.mz_audit_events
      →Arrange (#0)
        →Union
          →Fused with Child Map/Filter/Project
            Project: #4, #3, #5
            Filter: (#0{event_type} = "drop") AND (#1{object_type} = "cluster-replica") AND (#4) IS NOT NULL
            Map: true
              →Read mz_catalog.mz_audit_events
          →Map/Filter/Project
            Project: #0..=#2
            Map: null, null
              →Threshold Diffs #0
                →Arrange (#0)
                  →Consolidating Union
                    →Negate Diffs
                      →Fused with Child Map/Filter/Project
                        Project: #3
                        Filter: (#0{event_type} = "drop") AND (#1{object_type} = "cluster-replica") AND (#3) IS NOT NULL
                          →Read l0
                    →Unarranged Raw Stream
                      →Distinct GroupAggregate
                        →Fused with Child Map/Filter/Project
                          Project: #3
                          Filter: (#0{event_type} = "create") AND (#1{object_type} = "cluster-replica") AND NOT(like["s%"]((#2{details} ->> "cluster_id"))) AND (#3) IS NOT NULL
                            →Read l0
      →Arrange (#0)
        →Union
          →Fused with Child Map/Filter/Project
            Project: #0, #6, #7
            Map: true
              →Arranged mz_catalog.mz_cluster_replica_sizes
                Key: (#0{size})
          →Map/Filter/Project
            Project: #0..=#2
            Map: null, null
              →Threshold Diffs #0
                →Arrange (#0)
                  →Consolidating Union
                    →Negate Diffs
                      →Fused with Child Map/Filter/Project
                        Project: #0
                          →Arranged mz_catalog.mz_cluster_replica_sizes
                            Key: (#0{size})
                    →Unarranged Raw Stream
                      →Distinct GroupAggregate
                        →Union
                          →Fused with Child Map/Filter/Project
                            Project: #5
                            Filter: (#0{event_type} = "create") AND (#1{object_type} = "cluster-replica") AND NOT(like["s%"]((#2{details} ->> "cluster_id"))) AND (#4) IS NOT NULL
                            Map: (#2{details} ->> "logical_size")
                              →Read mz_catalog.mz_audit_events
                          →Constant (1 row)

Source mz_catalog.mz_audit_events
  project=(#1..=#3, #5, #6)
  filter=((#2{object_type} = "cluster-replica") AND (#6) IS NOT NULL)
  map=((#3{details} ->> "replica_id"))

Used Indexes:
  - mz_catalog.mz_cluster_replica_sizes_ind (*** full scan ***)

Target cluster: mz_catalog_server

EOF

