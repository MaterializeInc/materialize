query T multiline
EXPLAIN INDEX "mz_catalog"."mz_objects_ind";
----
mz_catalog.mz_objects_ind:
  →Arrange (#2{schema_id})
    →Stream mz_catalog.mz_objects

mz_catalog.mz_objects:
  →With
    cte l0 =
      →Union
        →Fused with Child Map/Filter/Project
          Project: #1, #2, #0, #3, #9, #4, #10, #5
          Map: "table", null
            →Arranged mz_catalog.mz_tables
              Key: (#2{schema_id})
        →Fused with Child Map/Filter/Project
          Project: #0..=#3, #15, #11, #10, #12
          Map: "source"
            →Arranged mz_catalog.mz_sources
              Key: (#0{id})
        →Fused with Child Map/Filter/Project
          Project: #1, #2, #0, #3, #9, #5, #10, #6
          Map: "view", null
            →Arranged mz_catalog.mz_views
              Key: (#2{schema_id})
        →Fused with Child Map/Filter/Project
          Project: #0..=#3, #10, #6, #4, #7
          Map: "materialized-view"
            →Arranged mz_catalog.mz_materialized_views
              Key: (#0{id})
  →Return
    →Union
      →Stream l0
      →Fused with Child Map/Filter/Project
        Project: #0..=#3, #15, #12, #11, #16
        Map: "sink", null
          →Arranged mz_catalog.mz_sinks
            Key: (#0{id})
      →Differential Join %0:mz_indexes[#3{on_id}] » %1:l0[#0{id}]
        Final closure:
          Project: #0, #1, #5, #2, #6, #4, #3, #7
          Map: "index", null
        →Arrange (#3{on_id})
          →Fused with Child Map/Filter/Project
            Project: #0..=#5
              →Arranged mz_catalog.mz_indexes
                Key: (#0{id})
        →Arrange (#0{id})
          →Fused with Child Map/Filter/Project
            Project: #0, #2
              →Read l0
      →Fused with Child Map/Filter/Project
        Project: #1, #2, #0, #3, #9, #5, #10, #6
        Map: "connection", null
          →Arranged mz_catalog.mz_connections
            Key: (#2{schema_id})
      →Fused with Child Map/Filter/Project
        Project: #1, #2, #0, #3, #9, #5, #10, #6
        Map: "type", null
          →Arranged mz_catalog.mz_types
            Key: (#2{schema_id})
      →Read mz_catalog.mz_functions
      →Fused with Child Map/Filter/Project
        Project: #1..=#3, #0, #6, #4, #7, #5
        Map: "secret", null
          →Arranged mz_catalog.mz_secrets
            Key: (#3{name})

Source mz_catalog.mz_functions
  project=(#0..=#3, #9, #8, #10, #11)
  map=("function", null, null)

Used Indexes:
