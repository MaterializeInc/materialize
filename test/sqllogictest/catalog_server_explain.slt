    →Arrange (#1{prepared_statement_id})
      →Read mz_internal.mz_statement_execution_history
    →Arrange (#0{id}) (#1{session_id})
      →Read mz_internal.mz_prepared_statement_history
    →Arrange (#0{session_id})
      →Read mz_internal.mz_session_history

Source mz_internal.mz_statement_execution_history
  filter=((mz_now() < timestamp_tz_to_mz_timestamp((#14{began_at} + 1 day))))
Source mz_internal.mz_prepared_statement_history
