                            →Read l0
                  →Stream l1
            →Fused with Child Map/Filter/Project
              Project: #1..=#3, #5
              Filter: (#0{event_type} = "create")
                →Read l0
        →Arranged l2
    cte l4 =
      →Arrange (#2{id})
        →Stream l3
    cte l5 =
      →Delta Join [%0:l4[#2{id}] » %1:mz_audit_events[(#1{details} ->> "id")] » %2:l2[#0]] [%1:mz_audit_events[#0] » %2:l2[#0] » %0:l4[#2{id}]] [%2:l2[#0] » %1:mz_audit_events[#0] » %0:l4[#2{id}]]
        →Arranged l4
