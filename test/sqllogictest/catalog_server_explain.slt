mz_internal.mz_sink_statuses_ind:
  →Arrange (#0{id})
    →Stream mz_internal.mz_sink_statuses

mz_internal.mz_sink_statuses:
  →With
    cte l0 =
      →Fused with Child Map/Filter/Project
        Project: #1, #0, #2..=#4, #6
        Map: coalesce(#5{replica_id}, "<sink>")
          →Arranged mz_internal.mz_sink_status_history
            Key: (#1{sink_id})
    cte l1 =
      →Distinct GroupAggregate
        →Fused with Child Map/Filter/Project
          Project: #5
            →Read l0
    cte l2 =
      →Differential Join %0:l1[#0] » %1:mz_cluster_replicas[#0{id}]
        →Arranged l1
        →Arranged mz_catalog.mz_cluster_replicas
    cte l3 =
      →Differential Join %0:mz_sinks[#0{id}] » %1[#1]
        after %1:
          Project: #0, #3, #4, #15..=#18
          Filter: NOT(like["s%"](#0))
        →Arranged mz_catalog.mz_sinks
        →Arrange (#1)
          →Map/Filter/Project
            Project: #0..=#4
              →Non-monotonic TopK
                Group By #1
                Order By #5 asc nulls_last, #0 desc nulls_first
                Limit 1
                →Map/Filter/Project
                  Project: #0..=#4, #6
                  Map: case when (#2{status} = "dropped") then 1 else case when (#2{status} = "running") then 2 else case when (#2{status} = "stalled") then 3 else case when (#2{status} = "starting") then 4 else case when (#2{status} = "paused") then 5 else case when (#2{status} = "ceased") then 6 else 7 end end end end end end
                    →Non-monotonic TopK
                      Group By #1, #5
                      Order By #0 desc nulls_first
