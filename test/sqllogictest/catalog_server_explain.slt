          →Distinct GroupAggregate
            →Union
              →Unarranged Raw Stream
                →Arranged mz_introspection.mz_compute_error_counts_raw
              →Delta Join [%0:l2[#0{export_id}] » %1:l0[#1{index_id}] » %2[#0]] [%1:l0[#1{index_id}] » %0:l2[#0{export_id}] » %2[#0]] [%2[#0] » %1:l0[#2] » %0:l2[#0{export_id}]]
                →Arrange (#0{export_id})
                  →Stream l2
                →Arrange (#1{index_id}) (#2)
                  →Stream l0
                →Arrange (#0)
                  →Consolidating Union
                    →Negate Diffs
                      →Differential Join %0:l1[#0] » %1[#0]
                        →Arranged l1
                        →Distinct GroupAggregate
                          Key:
                            Project: #1
                            Map: list_index(#0{address}, 1)
                          →Differential Join %0:mz_dataflow_addresses_per_worker[#0{id}] » %1:mz_dataflow_operators_per_worker[#0{id}]
                            →Arrange (#0{id})
                              →Fused with Child Map/Filter/Project
                                Project: #0, #2
                                Filter: (#1{worker_id} = 0) AND (1 = list_length(#2{address})) AND (list_index(#2{address}, 1)) IS NOT NULL
                                  →Arranged mz_introspection.mz_dataflow_addresses_per_worker
                                    Key: (#0, #1)
