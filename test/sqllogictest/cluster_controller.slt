# Boundary test for the cluster controller (PR 2): with the master gate forced
# on and the tick interval driven down so the controller demonstrably reconciles
# many times within the test window, the baseline-only controller must reconcile
# a steady managed cluster to a no-op. With only the implicit baseline strategy
# the desired replica set equals the realized one, so the controller never
# creates, drops, or renames a replica no matter how often it ticks.

mode cockroach

reset-server

# Force the gate on and drive the tick interval down to a few milliseconds, so
# the controller ticks ~hundreds of times across the bounded wait below. The gate
# is re-read each tick, so the flip takes effect without a restart.
simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_cluster_controller = true
----
COMPLETE 0

simple conn=mz_system,user=mz_system
ALTER SYSTEM SET cluster_controller_tick_interval = '5ms'
----
COMPLETE 0

# The graceful-reconfiguration cases below use the WITH (WAIT ...) surface, whose
# planner acceptance is still gated on this flag even when the controller owns the
# reconfiguration.
simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_zero_downtime_cluster_reconfiguration = true
----
COMPLETE 0

statement ok
CREATE CLUSTER cc_steady (SIZE 'scale=1,workers=1', REPLICATION FACTOR 2)

# The baseline desires exactly the realized set: two replicas at the cluster
# size. The controller, even with the gate on, leaves them untouched.
query TTT rowsort
SELECT cluster, replica, size FROM (SHOW CLUSTER REPLICAS) WHERE cluster = 'cc_steady' ORDER BY 1, 2, 3
----
cc_steady  r1  scale=1,workers=1
cc_steady  r2  scale=1,workers=1

# Give the controller a window that spans many tick intervals (5ms) so the
# reconcile loop runs against this cluster repeatedly. A baseline-only controller
# must emit zero decisions every tick.
statement ok
SELECT mz_unsafe.mz_sleep(2)

# After ~hundreds of ticks the replica set is still exactly the one CREATE
# CLUSTER allocated: same names, same sizes, same count.
query TTT rowsort
SELECT cluster, replica, size FROM (SHOW CLUSTER REPLICAS) WHERE cluster = 'cc_steady' ORDER BY 1, 2, 3
----
cc_steady  r1  scale=1,workers=1
cc_steady  r2  scale=1,workers=1

# A controller that churned a steady replica — dropped and recreated it, even
# reusing the same name — would leave a dropped replica in the history. The
# baseline controller must never drop a steady replica, so cc_steady has no
# dropped replica recorded. (Materialize forbids copying these system rows into a
# user table, so we assert no-drop directly rather than snapshotting ids into a
# baseline table.) This distinguishes a correctly no-op controller from one that
# silently recreates replicas; it is not satisfied by gate-off legacy behavior,
# which never runs the reconcile loop at all.
query I
SELECT count(*) FROM mz_internal.mz_cluster_replica_history
WHERE cluster_name = 'cc_steady' AND dropped_at IS NOT NULL
----
0

# A replication-factor change is still a normal, immediate config update (PR 2
# does not reshape ALTER); the controller then reconciles to the new steady set
# without churn. Wait across many ticks again and assert the controller settled
# on exactly one replica and did not keep churning.
statement ok
ALTER CLUSTER cc_steady SET (REPLICATION FACTOR 1)

statement ok
SELECT mz_unsafe.mz_sleep(2)

query TTT rowsort
SELECT cluster, replica, size FROM (SHOW CLUSTER REPLICAS) WHERE cluster = 'cc_steady' ORDER BY 1, 2, 3
----
cc_steady  r1  scale=1,workers=1

# The controller retired the surplus replica, so the drop is audited `retired`
# even though the replication-factor change was user-initiated.
query TT
SELECT event_type, details->>'reason'
FROM mz_catalog.mz_audit_events
WHERE event_type = 'drop'
  AND object_type = 'cluster-replica'
  AND details->>'cluster_name' = 'cc_steady'
----
drop  retired

statement ok
DROP CLUSTER cc_steady

# ----- Graceful background reconfiguration (PR 3) -----
#
# With the master gate on and background ALTER enabled, a config-shape ALTER
# (SIZE change) writes a durable reconfiguration record and returns immediately;
# the controller creates the target replicas, and once they hydrate (an empty
# cluster hydrates promptly) cuts the realized size over to the target and drops
# the old replicas.

simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_background_alter_cluster = true
----
COMPLETE 0

statement ok
CREATE CLUSTER cc_graceful (SIZE 'scale=1,workers=1', REPLICATION FACTOR 1)

# Background ALTER returns immediately (no session-side wait).
statement ok
ALTER CLUSTER cc_graceful SET (SIZE 'scale=1,workers=2')

# Give the controller time to spin up the target replica, hydrate it, cut over,
# and drop the old replica.
statement ok
SELECT mz_unsafe.mz_sleep(4)

# The realized config has cut over to the target size, and the cluster settled
# back to exactly REPLICATION FACTOR replicas at the new size.
query T
SELECT size FROM mz_clusters WHERE name = 'cc_graceful'
----
scale=1,workers=2

query TTT rowsort
SELECT cluster, replica, size FROM (SHOW CLUSTER REPLICAS) WHERE cluster = 'cc_graceful' ORDER BY 1, 2, 3
----
cc_graceful  r2  scale=1,workers=2

# The in-flight reconfiguration record was cleared after cut-over, so a fresh
# config-shape ALTER (to a third size) writes a new record and reshapes again
# rather than folding onto a stale one. This genuinely exercises the
# record-write/converge/cut-over path a second time (an identical no-op ALTER
# would early-return before ever reaching the reshape branch and prove nothing).
statement ok
ALTER CLUSTER cc_graceful SET (SIZE 'scale=1,workers=1')

statement ok
SELECT mz_unsafe.mz_sleep(4)

query T
SELECT size FROM mz_clusters WHERE name = 'cc_graceful'
----
scale=1,workers=1

query TTT rowsort
SELECT cluster, replica, size FROM (SHOW CLUSTER REPLICAS) WHERE cluster = 'cc_graceful' ORDER BY 1, 2, 3
----
cc_graceful  r3  scale=1,workers=1

# Replica lifecycle attribution: the CREATE CLUSTER replica is `manual`, each
# reconfiguration's target replica carries `reconfiguration`, and every
# controller drop (the old set retired at cut-over) is `retired`.
query TT
SELECT event_type, details->>'reason'
FROM mz_catalog.mz_audit_events
WHERE object_type = 'cluster-replica'
  AND details->>'cluster_name' = 'cc_graceful'
ORDER BY id
----
create  manual
create  reconfiguration
drop  retired
create  reconfiguration
drop  retired

statement ok
DROP CLUSTER cc_graceful

# ----- Per-ALTER timeout / ON TIMEOUT (PR 3) -----
#
# The deadline and the on-timeout action come from the existing WITH (WAIT ...)
# surface and are written into the durable reconfiguration record, so the
# controller (not the session) enforces them. These cases use a promptly-hydrating
# (empty) cluster, so success precedence cuts over before any deadline matters;
# they assert the three spellings are accepted under the gate and drive the record
# to a successful cut-over. The ROLLBACK-vs-COMMIT behavior *at* a timeout (a
# target that never hydrates) is asserted deterministically in the controller's
# kernel unit tests, where hydration does not race the deadline.

statement ok
CREATE CLUSTER cc_timeout (SIZE 'scale=1,workers=1', REPLICATION FACTOR 1)

# Omitting WITH (WAIT ...) entirely: the record takes the default deadline and
# the default ON TIMEOUT action, which is now ROLLBACK. The target hydrates, so it
# cuts over regardless.
statement ok
ALTER CLUSTER cc_timeout SET (SIZE 'scale=1,workers=2')

statement ok
SELECT mz_unsafe.mz_sleep(4)

query T
SELECT size FROM mz_clusters WHERE name = 'cc_timeout'
----
scale=1,workers=2

# Explicit ON TIMEOUT ROLLBACK with a generous deadline: success precedence still
# cuts over.
statement ok
ALTER CLUSTER cc_timeout SET (SIZE 'scale=1,workers=4') WITH (WAIT UNTIL READY (TIMEOUT '60s', ON TIMEOUT 'ROLLBACK'))

statement ok
SELECT mz_unsafe.mz_sleep(4)

query T
SELECT size FROM mz_clusters WHERE name = 'cc_timeout'
----
scale=1,workers=4

# Explicit ON TIMEOUT COMMIT (and WAIT FOR, which desugars to ON TIMEOUT COMMIT):
# both accepted under the gate and drive a cut-over.
statement ok
ALTER CLUSTER cc_timeout SET (SIZE 'scale=1,workers=2') WITH (WAIT UNTIL READY (TIMEOUT '60s', ON TIMEOUT 'COMMIT'))

statement ok
SELECT mz_unsafe.mz_sleep(4)

query T
SELECT size FROM mz_clusters WHERE name = 'cc_timeout'
----
scale=1,workers=2

statement ok
ALTER CLUSTER cc_timeout SET (SIZE 'scale=1,workers=1') WITH (WAIT FOR '60s')

statement ok
SELECT mz_unsafe.mz_sleep(4)

query T
SELECT size FROM mz_clusters WHERE name = 'cc_timeout'
----
scale=1,workers=1

statement ok
DROP CLUSTER cc_timeout

# ----- Observability: introspection view + SHOW CLUSTERS (PR 4) -----
#
# mz_internal.mz_cluster_reconfigurations reports, per managed cluster, the
# realized config and the in-flight reconfiguration target. In steady state (no
# record in flight) the target columns mirror the current ones and the in-flight
# flag is false. The records are written only by the (gated) controller, so for a
# settled cluster the two shapes coincide.

statement ok
CREATE CLUSTER cc_obs (SIZE 'scale=1,workers=1', REPLICATION FACTOR 2)

statement ok
SELECT mz_unsafe.mz_sleep(2)

# Steady state: current == target, nothing in flight, no deadline, no burst.
query TITIBBBB
SELECT current_size, current_replication_factor, target_size, target_replication_factor,
       reconfiguration_in_flight, reconfiguration_deadline IS NOT NULL, burst_size IS NOT NULL,
       (current_size = target_size AND current_replication_factor = target_replication_factor)
FROM mz_internal.mz_cluster_reconfigurations recon
JOIN mz_clusters ON mz_clusters.id = recon.cluster_id
WHERE mz_clusters.name = 'cc_obs'
----
scale=1,workers=1  2  scale=1,workers=1  2  false  false  false  true

# SHOW CLUSTERS surfaces the realized (current) and target size and the in-flight
# indicator. For a settled cluster current == target and reconfiguration is null.
query TTTB
SELECT name, current_size, target_size, reconfiguration_in_flight
FROM (SHOW CLUSTERS) WHERE name = 'cc_obs'
----
cc_obs  scale=1,workers=1  scale=1,workers=1  false

# A completed background reconfiguration advances both current and target to the
# new size, and clears the in-flight record.
statement ok
ALTER CLUSTER cc_obs SET (SIZE 'scale=1,workers=2')

statement ok
SELECT mz_unsafe.mz_sleep(4)

query TTTB
SELECT name, current_size, target_size, reconfiguration_in_flight
FROM (SHOW CLUSTERS) WHERE name = 'cc_obs'
----
cc_obs  scale=1,workers=2  scale=1,workers=2  false

# The audit log captured the reconfiguration lifecycle: a `started` event when the
# record was written, and a `finalized` event at cut-over. Every transition records
# the active deadline; on `finalized` a reader compares it to the event's
# occurred_at to tell an in-time cut-over from a late or forced one.
query TB
SELECT
    details->>'transition',
    details->>'deadline' IS NOT NULL
FROM mz_catalog.mz_audit_events
WHERE event_type = 'alter'
  AND object_type = 'cluster'
  AND details->>'cluster_name' = 'cc_obs'
  AND details->>'transition' IS NOT NULL
ORDER BY id
----
started  true
finalized  true

statement ok
DROP CLUSTER cc_obs

# An ALTER-back cancel: a reconfiguration is started and then re-targeted back to
# the cluster's still-realized size before it cuts over. The lifecycle records a
# `started`, then a `cancelled` at the ALTER-back (the in-flight target replicas
# are dropped and the record converges), then a `finalized` as the now-trivial
# (target == realized) reconfiguration clears.
statement ok
CREATE CLUSTER cc_cancel (SIZE 'scale=1,workers=1', REPLICATION FACTOR 1)

statement ok
SELECT mz_unsafe.mz_sleep(2)

statement ok
ALTER CLUSTER cc_cancel SET (SIZE 'scale=1,workers=2')

statement ok
ALTER CLUSTER cc_cancel SET (SIZE 'scale=1,workers=1')

statement ok
SELECT mz_unsafe.mz_sleep(4)

# The cluster is back at its original realized size and nothing is in flight.
query TTTB
SELECT name, current_size, target_size, reconfiguration_in_flight
FROM (SHOW CLUSTERS) WHERE name = 'cc_cancel'
----
cc_cancel  scale=1,workers=1  scale=1,workers=1  false

query T
SELECT details->>'transition'
FROM mz_catalog.mz_audit_events
WHERE event_type = 'alter'
  AND object_type = 'cluster'
  AND details->>'cluster_name' = 'cc_cancel'
  AND details->>'transition' IS NOT NULL
ORDER BY id
----
started
cancelled
finalized

statement ok
DROP CLUSTER cc_cancel

# ----- Rollback at the deadline (PR 8b): record cleared + timed-out event -----
#
# A reconfiguration whose deadline passes before the target hydrates under
# ON TIMEOUT ROLLBACK is abandoned: the controller drops the target set and
# clears the record without touching the realized config, and the audit log
# records a `timed-out` transition — the timeout's only papertrail. A TIMEOUT
# of '0s' puts the deadline in the past for any realistic controller tick, so
# the rollback happens promptly — though a transient target replica is possible
# (the deadline comparison is strict, so a tick landing in the very same
# millisecond as the deadline still desires the target for one tick). The
# assertions below tolerate that: the audit query filters on `transition IS NOT
# NULL`, and the replica check runs seconds after the rollback has settled.

statement ok
CREATE CLUSTER cc_rollback (SIZE 'scale=1,workers=1', REPLICATION FACTOR 1)

statement ok
ALTER CLUSTER cc_rollback SET (SIZE 'scale=1,workers=2') WITH (WAIT UNTIL READY (TIMEOUT '0s', ON TIMEOUT 'ROLLBACK'))

statement ok
SELECT mz_unsafe.mz_sleep(4)

# Rolled back: the realized config is untouched and nothing is in flight — the
# record is gone, so the view reads exactly like a settled cluster.
query TTB
SELECT recon.current_size, recon.target_size, recon.reconfiguration_in_flight
FROM mz_internal.mz_cluster_reconfigurations recon
JOIN mz_clusters ON mz_clusters.id = recon.cluster_id
WHERE mz_clusters.name = 'cc_rollback'
----
scale=1,workers=1  scale=1,workers=1  false

query T
SELECT size FROM mz_clusters WHERE name = 'cc_rollback'
----
scale=1,workers=1

# The replica set stayed at the realized shape: no target replica survives a
# rollback (any transient one has been retired by the time we check, seconds
# after the rollback).
query TT rowsort
SELECT replica, size FROM (SHOW CLUSTER REPLICAS) WHERE cluster = 'cc_rollback'
----
r1  scale=1,workers=1

# The timeout firing is in the history exactly once — the record clear is
# durable, so the transition cannot re-fire no matter how many ticks pass. The
# event carries the deadline and the abandoned target, which survive nowhere
# else.
query TTB
SELECT details->>'transition', details->>'target_size', details->>'deadline' IS NOT NULL
FROM mz_catalog.mz_audit_events
WHERE event_type = 'alter'
  AND object_type = 'cluster'
  AND details->>'cluster_name' = 'cc_rollback'
  AND details->>'transition' IS NOT NULL
ORDER BY id
----
started  scale=1,workers=2  true
timed-out  scale=1,workers=2  true

# A forced cut-over: TIMEOUT '0s' with ON TIMEOUT COMMIT advances the realized
# config to the (necessarily un-hydrated) target on the controller's first tick.
# The clear classifies `finalized` — the realized config did cut over — with the
# deadline carried so the history shows it was a past-deadline (forced) cut-over.
statement ok
ALTER CLUSTER cc_rollback SET (SIZE 'scale=1,workers=2') WITH (WAIT UNTIL READY (TIMEOUT '0s', ON TIMEOUT 'COMMIT'))

statement ok
SELECT mz_unsafe.mz_sleep(4)

query TB
SELECT recon.current_size, recon.reconfiguration_in_flight
FROM mz_internal.mz_cluster_reconfigurations recon
JOIN mz_clusters ON mz_clusters.id = recon.cluster_id
WHERE mz_clusters.name = 'cc_rollback'
----
scale=1,workers=2  false

# A reconfiguration that has not yet converged is in flight. To observe the
# transient state deterministically, freeze the controller by flipping the
# master gate off right after the record is written (both are re-read each
# tick): the record then cannot move. The flip lands within milliseconds of the
# ALTER returning, while a cut-over first needs a target replica process to boot
# and report hydration.
statement ok
ALTER CLUSTER cc_rollback SET (SIZE 'scale=1,workers=4') WITH (WAIT UNTIL READY (TIMEOUT '60s', ON TIMEOUT 'ROLLBACK'))

simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_cluster_controller = false
----
COMPLETE 0

query BTT
SELECT recon.reconfiguration_in_flight, recon.current_size, recon.target_size
FROM mz_internal.mz_cluster_reconfigurations recon
JOIN mz_clusters ON mz_clusters.id = recon.cluster_id
WHERE mz_clusters.name = 'cc_rollback'
----
true  scale=1,workers=2  scale=1,workers=4

# Unfreeze: the controller converges the in-flight record and settles.
simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_cluster_controller = true
----
COMPLETE 0

statement ok
SELECT mz_unsafe.mz_sleep(4)

query TB
SELECT recon.current_size, recon.reconfiguration_in_flight
FROM mz_internal.mz_cluster_reconfigurations recon
JOIN mz_clusters ON mz_clusters.id = recon.cluster_id
WHERE mz_clusters.name = 'cc_rollback'
----
scale=1,workers=4  false

# The full lifecycle history for this cluster, in order: the rolled-back
# attempt, the forced COMMIT cut-over, and the frozen-then-converged success.
# Every transition carries the deadline.
query TB
SELECT details->>'transition', details->>'deadline' IS NOT NULL
FROM mz_catalog.mz_audit_events
WHERE event_type = 'alter'
  AND object_type = 'cluster'
  AND details->>'cluster_name' = 'cc_rollback'
  AND details->>'transition' IS NOT NULL
ORDER BY id
----
started  true
timed-out  true
started  true
finalized  true
started  true
finalized  true

statement ok
DROP CLUSTER cc_rollback

# ON REFRESH scheduling driven by the controller (PR 5). With the gate on, the
# on-refresh strategy — not the legacy cluster_scheduling.rs tick — owns a
# scheduled cluster's replica set: it normalizes the realized replication factor
# to 0 and brings up a single replica while the cluster is inside a refresh
# window. The behavior must match today's scheduler.

# A scheduled cluster with no bound REFRESH MV is outside any refresh window, so
# it has no replica and its replication factor reads 0. The large HYDRATION TIME
# ESTIMATE below makes the window deterministically open once a fast-refreshing MV
# is bound (the cluster must always be on to stay that far ahead of the next
# refresh), so the in-window assertions don't race the refresh cadence.
statement ok
CREATE CLUSTER cc_sched (
  SIZE 'scale=1,workers=1',
  SCHEDULE = ON REFRESH (HYDRATION TIME ESTIMATE = '60 seconds'))

statement ok
SELECT mz_unsafe.mz_sleep(2)

query I
SELECT replication_factor FROM mz_catalog.mz_clusters WHERE name = 'cc_sched'
----
0

query I
SELECT count(*) FROM mz_cluster_replicas r
JOIN mz_clusters c ON r.cluster_id = c.id WHERE c.name = 'cc_sched'
----
0

# Bind a REFRESH EVERY materialized view: the cluster is now inside a refresh
# window (it must rehydrate ahead of each refresh), so the controller brings up
# exactly one replica at the cluster size. The replication factor still reads 0 —
# it is the controller's domain for a scheduled cluster — and mz_cluster_replicas
# is authoritative for what is actually running.
statement ok
CREATE TABLE sched_t (x int)

statement ok
CREATE MATERIALIZED VIEW cc_sched_mv IN CLUSTER cc_sched
  WITH (REFRESH = EVERY '1 second') AS SELECT count(*) FROM sched_t

statement ok
SELECT mz_unsafe.mz_sleep(4)

query I
SELECT replication_factor FROM mz_catalog.mz_clusters WHERE name = 'cc_sched'
----
0

query I
SELECT count(*) FROM mz_cluster_replicas r
JOIN mz_clusters c ON r.cluster_id = c.id WHERE c.name = 'cc_sched'
----
1

# The replica runs at the cluster size, and the MV computes a result on it.
query T
SELECT r.size FROM mz_cluster_replicas r
JOIN mz_clusters c ON r.cluster_id = c.id WHERE c.name = 'cc_sched'
----
scale=1,workers=1

query I
SELECT count FROM cc_sched_mv
----
0

statement ok
DROP MATERIALIZED VIEW cc_sched_mv

# With the MV gone the refresh window closes and the controller retires the
# replica.
statement ok
SELECT mz_unsafe.mz_sleep(2)

query I
SELECT count(*) FROM mz_cluster_replicas r
JOIN mz_clusters c ON r.cluster_id = c.id WHERE c.name = 'cc_sched'
----
0

# The window-open create is audited `schedule` and carries the window decision
# as the `scheduling_policies` detail, like the legacy scheduler's creates did:
# the decision is `on`, the hydration-time estimate rides along, and the open
# window names the REFRESH MV behind it. The window-close drop is `retired`
# with no detail — a drop happens exactly when no strategy desires the replica,
# so there is no decision to record. (A scheduled cluster starts with no
# replicas, so these are the only replica events.)
query TTTTB
SELECT event_type, details->>'reason',
  details->'scheduling_policies'->'on_refresh'->>'decision',
  details->'scheduling_policies'->'on_refresh'->>'hydration_time_estimate',
  jsonb_array_length(details->'scheduling_policies'->'on_refresh'->'objects_needing_refresh') > 0
FROM mz_catalog.mz_audit_events
WHERE object_type = 'cluster-replica'
  AND details->>'cluster_name' = 'cc_sched'
ORDER BY id
----
create  schedule  on  00:01:00  true
drop  retired  NULL  NULL  NULL

statement ok
DROP TABLE sched_t

statement ok
DROP CLUSTER cc_sched

# A MANUAL cluster is untouched by the on-refresh strategy: its replica set is the
# user's replication factor, owned by the implicit baseline.
statement ok
CREATE CLUSTER cc_manual (SIZE 'scale=1,workers=1', REPLICATION FACTOR 1)

statement ok
SELECT mz_unsafe.mz_sleep(2)

query I
SELECT replication_factor FROM mz_catalog.mz_clusters WHERE name = 'cc_manual'
----
1

query I
SELECT count(*) FROM mz_cluster_replicas r
JOIN mz_clusters c ON r.cluster_id = c.id WHERE c.name = 'cc_manual'
----
1

statement ok
DROP CLUSTER cc_manual

# ----- Hydration burst (PR 6): AUTO SCALING STRATEGY SQL surface. -----

# SQL acceptance is gated by a feature flag (not a dyncfg) so stored CREATE CLUSTER
# statements re-parse at rehydration regardless of the dyncfgs.
simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_auto_scaling_strategy = true
----
COMPLETE 0

# These checks exercise the AUTO SCALING STRATEGY SQL surface (parse, render,
# validation), not live burst arming — the controller's own tests cover arming, and
# it is non-deterministic here (an arming burst races the steady replica's boot and
# hydration, then lingers). Disable the break-glass burst strategy so the in-flight
# burst state is deterministically empty.
simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_hydration_burst = false
----
COMPLETE 0

# A managed cluster can carry an ON HYDRATION burst policy.
statement ok
CREATE CLUSTER cc_burst (SIZE 'scale=1,workers=1', AUTO SCALING STRATEGY = (ON HYDRATION (HYDRATION SIZE = 'scale=2,workers=2', LINGER DURATION = '600s')))

# SHOW CREATE CLUSTER renders the policy back, and the rendered statement re-parses
# (the planner's create-roundtrip asserts unplan->parse->plan equality, so a faulty
# render would already have failed the CREATE above). The rendered SQL mentions the
# block.
query T
SELECT create_sql LIKE '%AUTO SCALING STRATEGY = (ON HYDRATION (HYDRATION SIZE = ''scale=2,workers=2''%' FROM (SHOW CREATE CLUSTER cc_burst)
----
true

# The cluster serves a steady replica set at its own size (the baseline).
query I
SELECT replication_factor FROM mz_catalog.mz_clusters WHERE name = 'cc_burst'
----
1

# SHOW CLUSTERS surfaces the burst column; with the burst strategy disabled no burst
# is ever in flight, so it reads NULL.
query TT
SELECT name, burst_size FROM (SHOW CLUSTERS) WHERE name = 'cc_burst'
----
cc_burst  NULL

# RESET disables autoscaling; SHOW CREATE no longer renders the block.
statement ok
ALTER CLUSTER cc_burst RESET (AUTO SCALING STRATEGY)

query T
SELECT create_sql LIKE '%AUTO SCALING STRATEGY%' FROM (SHOW CREATE CLUSTER cc_burst)
----
false

# Setting it back via ALTER also works (omitting LINGER DURATION).
statement ok
ALTER CLUSTER cc_burst SET (AUTO SCALING STRATEGY = (ON HYDRATION (HYDRATION SIZE = 'scale=2,workers=2')))

query T
SELECT create_sql LIKE '%AUTO SCALING STRATEGY = (ON HYDRATION (HYDRATION SIZE = ''scale=2,workers=2''))%' FROM (SHOW CREATE CLUSTER cc_burst)
----
true

statement ok
DROP CLUSTER cc_burst

# HYDRATION SIZE equal to the cluster SIZE is rejected (a burst at the same size
# would not accelerate hydration).
statement error HYDRATION SIZE must differ from the cluster SIZE
CREATE CLUSTER cc_burst_bad (SIZE 'scale=1,workers=1', AUTO SCALING STRATEGY = (ON HYDRATION (HYDRATION SIZE = 'scale=1,workers=1')))

# AUTO SCALING STRATEGY combined with a non-MANUAL SCHEDULE is rejected.
statement error AUTO SCALING STRATEGY cannot be combined with a SCHEDULE other than MANUAL
CREATE CLUSTER cc_burst_sched (SIZE 'scale=1,workers=1', SCHEDULE = ON REFRESH, AUTO SCALING STRATEGY = (ON HYDRATION (HYDRATION SIZE = 'scale=2,workers=2')))

# The two invariants are also enforced when an ALTER changes the *other* side of
# the constraint on a cluster that already carries a strategy.
statement ok
CREATE CLUSTER cc_burst_alt (SIZE 'scale=1,workers=1', AUTO SCALING STRATEGY = (ON HYDRATION (HYDRATION SIZE = 'scale=2,workers=2')))

# Setting SIZE equal to the existing HYDRATION SIZE would make the burst a no-op.
statement error HYDRATION SIZE must differ from the cluster SIZE
ALTER CLUSTER cc_burst_alt SET (SIZE = 'scale=2,workers=2')

# Setting a non-MANUAL SCHEDULE on a cluster that already has a strategy is rejected.
statement error AUTO SCALING STRATEGY cannot be combined with a SCHEDULE other than MANUAL
ALTER CLUSTER cc_burst_alt SET (SCHEDULE = ON REFRESH)

statement ok
DROP CLUSTER cc_burst_alt

# The invariants also fire when an ALTER *introduces* a strategy that conflicts with
# the cluster's current config (the strategy-set side, validated against the
# effective size and schedule).
statement ok
CREATE CLUSTER cc_burst_set (SIZE 'scale=1,workers=1')

# A HYDRATION SIZE equal to the cluster's current SIZE is rejected.
statement error HYDRATION SIZE must differ from the cluster SIZE
ALTER CLUSTER cc_burst_set SET (AUTO SCALING STRATEGY = (ON HYDRATION (HYDRATION SIZE = 'scale=1,workers=1')))

statement ok
DROP CLUSTER cc_burst_set

# Adding a strategy to a cluster whose current SCHEDULE is non-MANUAL is rejected.
statement ok
CREATE CLUSTER cc_burst_onref (SIZE 'scale=1,workers=1', SCHEDULE = ON REFRESH)

statement error AUTO SCALING STRATEGY cannot be combined with a SCHEDULE other than MANUAL
ALTER CLUSTER cc_burst_onref SET (AUTO SCALING STRATEGY = (ON HYDRATION (HYDRATION SIZE = 'scale=2,workers=2')))

statement ok
DROP CLUSTER cc_burst_onref

# With SQL acceptance gated off, the option is rejected at plan time.
simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_auto_scaling_strategy = false
----
COMPLETE 0

statement error AUTO SCALING STRATEGY. cluster option is not available
CREATE CLUSTER cc_burst_gated (SIZE 'scale=1,workers=1', AUTO SCALING STRATEGY = (ON HYDRATION (HYDRATION SIZE = 'scale=2,workers=2')))

# Restore pristine server state (including the tick-interval override).
reset-server
