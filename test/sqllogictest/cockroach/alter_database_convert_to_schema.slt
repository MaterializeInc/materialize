mode cockroach

# Not supported by Materialize.
onlyif cockroach
statement ok
CREATE DATABASE parent;
USE parent;
CREATE DATABASE pgdatabase;
USE test;

statement error Expected OWNER, found identifier "convert"
ALTER DATABASE parent CONVERT TO SCHEMA WITH PARENT pgdatabase
