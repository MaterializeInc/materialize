mode cockroach

# tenant-capability-override-opt: can_check_consistency=true

statement ok
CREATE TABLE foo (a int)

statement ok
INSERT INTO foo (a) VALUES (1)

query error unknown schema 'foo'
SELECT foo.bar()

query error function "pg_catalog\.defaults" does not exist
SELECT pg_catalog.defaults()

query error function "defaults" does not exist
SELECT defaults()

# Not supported by Materialize.
