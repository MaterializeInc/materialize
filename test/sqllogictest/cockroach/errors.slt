mode cockroach

statement error pgcode 42P01 Expected one of SET or RENAME or OWNER or RESET or ADD, found DROP
ALTER TABLE fake1 DROP COLUMN a

statement error pgcode 42P01 unknown catalog item 'fake2'
CREATE INDEX i ON fake2 (a)

statement error pgcode 42P01 Expected end of statement, found operator "@"
DROP INDEX fake3@i

statement error pgcode 42P01 unknown catalog item 'fake4'
DROP TABLE fake4

statement error pgcode 42P01 unknown catalog item 'fake5'
SHOW COLUMNS FROM fake5

statement error pgcode 42P01 unknown catalog item 'fake6'
INSERT INTO fake6 VALUES (1, 2)

statement error pgcode 42P01 unknown catalog item 'fake7'
SELECT * FROM fake7
