mode cockroach

# not supported yet
halt

# test OVERLAPS expression
query B
SELECT
(TIMESTAMP '2000-01-01 00:00:00',
TIMESTAMP '2000-01-01 01:00:00')
OVERLAPS
(TIMESTAMP '2000-01-01 00:30:00',
TIMESTAMP '2000-01-01 01:30:00');
----
true

query B
SELECT
(TIMESTAMP '2000-01-01 01:00:00',
TIMESTAMP '2000-01-01 00:00:00')
OVERLAPS
(TIMESTAMP '2000-01-01 00:30:00',
TIMESTAMP '2000-01-01 01:30:00');
----
true

