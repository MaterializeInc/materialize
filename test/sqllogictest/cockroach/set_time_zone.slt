mode cockroach

# not supported yet
halt

statement ok
SET TIME ZONE 0

query T
SHOW TIME ZONE
----
<-00>+00

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 +0000 UTC

statement ok
SET TIME ZONE 10

query T
SHOW TIME ZONE
----
<+10>-10

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 +1000 +1000

statement ok
SET TIME ZONE -10

query T
SHOW TIME ZONE
----
<-10>+10

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 -1000 -1000

statement ok
SET TIME ZONE '10'

query T
SHOW TIME ZONE
----
<+10>-10

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 +1000 +1000

statement ok
SET TIME ZONE '+10'

query T
SHOW TIME ZONE
----
<+10>-10

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 +1000 +1000

statement ok
SET TIME ZONE '-10'

query T
SHOW TIME ZONE
----
<-10>+10

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 -1000 -1000

statement ok
SET TIME ZONE '+10.5'

query T
SHOW TIME ZONE
----
<+10:30>-10:30

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 +1030 +1030

statement ok
SET TIME ZONE '-10.5'

query T
SHOW TIME ZONE
----
<-10:30>+10:30

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 -1030 -1030

statement ok
SET TIME ZONE '+10.555'

query T
SHOW TIME ZONE
----
<+10:33:18>-10:33:18

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 +1033 +1033

statement ok
SET TIME ZONE '-10.555'

query T
SHOW TIME ZONE
----
<-10:33:18>+10:33:18

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 -1033 -1033

statement ok
SET TIME ZONE '     +10'

query T
SHOW TIME ZONE
----
<+10>-10

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 +1000 +1000

statement ok
SET TIME ZONE '     -10'

query T
SHOW TIME ZONE
----
<-10>+10

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 -1000 -1000

statement ok
SET TIME ZONE 'GMT+3'

query T
SHOW TIME ZONE
----
GMT+3

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 -0300 -0300

statement ok
SET TIME ZONE 'GMT-3'

query T
SHOW TIME ZONE
----
GMT-3

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 +0300 +0300

statement ok
SET TIME ZONE 'UTC+3'

query T
SHOW TIME ZONE
----
UTC+3

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 -0300 -0300

statement ok
SET TIME ZONE 'UTC-3'

query T
SHOW TIME ZONE
----
UTC-3

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 +0300 +0300

statement ok
SET TIME ZONE 'Asia/Tokyo'

query T
SHOW TIME ZONE
----
Asia/Tokyo

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 +0900 +0900

statement ok
SET TIME ZONE 'zulu'

query T
SHOW TIME ZONE
----
Zulu

query T
SELECT TIME '05:40:00'::TIMETZ
----
0000-01-01 05:40:00 +0000 UTC

statement error pq: invalid value for parameter "timezone": "'168'": cannot find time zone "168": UTC timezone offset is out of range.
SET TIME ZONE '168'

statement error pq: invalid value for parameter "timezone": "'-168'": cannot find time zone "-168": UTC timezone offset is out of range.
SET TIME ZONE '-168'

statement error pq: invalid value for parameter "timezone": "'-0500'": cannot find time zone "-0500": UTC timezone offset is out of range.
SET TIME ZONE '-0500'

statement error pq: invalid value for parameter "timezone": "'0500'": cannot find time zone "0500": UTC timezone offset is out of range.
SET TIME ZONE '0500'

statement error pq: invalid value for parameter "timezone": "'-0500'": cannot find time zone "-0500": UTC timezone offset is out of range.
SET TIME ZONE '-0500'
