     d DATE NULL DEFAULT ‹×›:::DATE,
     rowid INT8 NOT VISIBLE NOT NULL DEFAULT unique_rowid(),
     CONSTRAINT d_pkey PRIMARY KEY (rowid ASC)
   )

statement ok
