     c CHAR NULL DEFAULT ‹×›:::STRING,
     rowid INT8 NOT VISIBLE NOT NULL DEFAULT unique_rowid(),
     CONSTRAINT c_pkey PRIMARY KEY (rowid ASC)
   )

statement ok
CREATE TABLE d (d DATE DEFAULT '1999-12-31')

# Not supported by Materialize.
onlyif cockroach
query TT
