# Not supported by Materialize.
onlyif cockroach
# Make sure function cannot be dropped if used in constraints
statement ok
CREATE TABLE t1(
  a INT PRIMARY KEY,
  b INT CHECK (f1(b) > 1),
  FAMILY fam_0 (a, b)
);

statement error Unsupported DROP on FUNCTION
