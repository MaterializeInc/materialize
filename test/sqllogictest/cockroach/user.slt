# Not supported by Materialize.
onlyif cockroach
statement ok
ALTER USER foo WITH PASSWORD 'somepass'

# Not supported by Materialize.
onlyif cockroach
statement ok
PREPARE chpw AS ALTER USER foo WITH PASSWORD $1;
  EXECUTE chpw('bar')

statement error Expected literal string, found parameter "\$1"
PREPARE chpw2 AS ALTER USER blix WITH PASSWORD $1;
  EXECUTE chpw2('baz')

# Not supported by Materialize.
onlyif cockroach
query TTT colnames
SHOW USERS
----
username  options  member_of
admin     ·        {}
