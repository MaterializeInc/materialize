mode cockroach

# LogicTest: local 3node-tenant

query T
SHOW is_superuser
----
off

# Not supported by Materialize.
onlyif cockroach
query TTT colnames
SHOW USERS
----
username  options  member_of
admin     ·        {}
root      ·        {admin}
testuser  ·        {}

# Not supported by Materialize.
onlyif cockroach
statement ok
CREATE USER user1

# Not supported by Materialize.
onlyif cockroach
query TTT colnames
SHOW USERS
----
username  options  member_of
admin     ·        {}
root      ·        {admin}
testuser  ·        {}
user1     ·        {}

