# Regression test for SQL-531.
#
# Replica ids and catalog-item ids come from separate allocators that both
# render as `u<N>`, so a cluster replica and a catalog item can share one id
# string. `mz_comments.id` is unambiguous only with `object_type`. The
# `mz_show_*` views must match `object_type` inside the `LEFT JOIN ... ON`, not
# in a trailing `WHERE`. A `WHERE` predicate drops the base row when the only
# comment on the colliding id belongs to the other object type.
#
# Each block checks the id collision it relies on before asserting view output,
# so the test fails loudly if allocation order changes.

mode cockroach

# ----------------------------------------------------------------------------
# Bug 1: SHOW CLUSTER REPLICAS must not drop replicas when a catalog item's
# comment collides with the replica id.
# ----------------------------------------------------------------------------

reset-server

# The bootstrap quickstart replica is u1.
query T
SELECT r.id
FROM mz_cluster_replicas r JOIN mz_clusters c ON r.cluster_id = c.id
WHERE c.name = 'quickstart'
----
u1

# The first user item lands on u1, colliding with the replica id.
statement ok
CREATE TABLE t (a int)

query T
SELECT id FROM mz_tables WHERE name = 't'
----
u1

statement ok
COMMENT ON TABLE t IS 'boom'

# Pre-fix: 0 rows, the replica vanished because the table's comment row
# (object_type='table') failed the trailing WHERE.
query TT
SELECT cluster, replica FROM mz_internal.mz_show_cluster_replicas
WHERE cluster = 'quickstart'
----
quickstart  r1

# ----------------------------------------------------------------------------
# Bug 2: SHOW OBJECTS must not drop objects when a colliding replica has a
# comment and the object itself does not.
# ----------------------------------------------------------------------------

reset-server

# A user cluster's replica lands on u2 (replica allocator), owned by the test
# user so it can be commented.
statement ok
CREATE CLUSTER c REPLICAS (r1 (SIZE 'scale=1,workers=1'))

statement ok
COMMENT ON CLUSTER REPLICA c.r1 IS 'replica_note'

# Two tables from the item allocator. The second lands on u2 and collides with
# cluster c's replica id. Neither table has a comment of its own.
statement ok
CREATE TABLE t1 (a int)

statement ok
CREATE TABLE t2 (a int)

# Confirm the collision this block depends on: replica id == table t2 id.
query T
SELECT (
    SELECT r.id FROM mz_cluster_replicas r JOIN mz_clusters c ON r.cluster_id = c.id
    WHERE c.name = 'c'
) = (SELECT id FROM mz_tables WHERE name = 't2')
----
true

# Pre-fix: t2 vanished because the replica's comment row
# (object_type='cluster-replica') failed `= objs.type ('table')` and IS NULL.
query TTT
SELECT name, type, comment FROM mz_internal.mz_show_all_objects WHERE name = 't2'
----
t2  table  (empty)

# The non-colliding table is unaffected.
query TTT
SELECT name, type, comment FROM mz_internal.mz_show_all_objects WHERE name = 't1'
----
t1  table  (empty)

# The replica comment is attributed to the replica, not the colliding table.
query TT
SELECT replica, comment FROM mz_internal.mz_show_cluster_replicas
WHERE cluster = 'c'
----
r1  replica_note

# ----------------------------------------------------------------------------
# Both the object and the colliding replica are commented: each view shows only
# its own comment, and neither base row is dropped.
# ----------------------------------------------------------------------------

reset-server

statement ok
CREATE CLUSTER c REPLICAS (r1 (SIZE 'scale=1,workers=1'))

statement ok
CREATE TABLE t1 (a int)

statement ok
CREATE TABLE t2 (a int)

query T
SELECT (
    SELECT r.id FROM mz_cluster_replicas r JOIN mz_clusters c ON r.cluster_id = c.id
    WHERE c.name = 'c'
) = (SELECT id FROM mz_tables WHERE name = 't2')
----
true

statement ok
COMMENT ON TABLE t2 IS 'table_note'

statement ok
COMMENT ON CLUSTER REPLICA c.r1 IS 'replica_note'

query TTT
SELECT name, type, comment FROM mz_internal.mz_show_all_objects WHERE name = 't2'
----
t2  table  table_note

query TT
SELECT replica, comment FROM mz_internal.mz_show_cluster_replicas
WHERE cluster = 'c'
----
r1  replica_note
