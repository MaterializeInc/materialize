mode cockroach

query T
SELECT current_user()
----
materialize

query T
SELECT current_role() = current_user()
----
true

query T
SELECT user() = current_user()
----
true

# CURRENT_USER and SESSION_USER are PostgreSQL role specification names, so
# a role named after them would be ambiguous in forms like
# "GRANT ... TO CURRENT_USER". Materialize reserves them and rejects such
# CREATE ROLE statements, matching PostgreSQL. role.slt covers the full set of
# reserved specification names. Sourced from the imported CockroachDB role
# logic test.
# PG: ERROR: CURRENT_USER cannot be used as a role name here
statement error role name "current_user" is reserved
CREATE ROLE CURRENT_USER

# PG: ERROR: SESSION_USER cannot be used as a role name here
statement error role name "session_user" is reserved
CREATE ROLE SESSION_USER
