query T multiline
EXPLAIN RAW PLAN AS TEXT FOR
WITH MUTUALLY RECURSIVE
    foo (a int, b int) AS (SELECT 1, 2 UNION SELECT a, 7 FROM bar),
    bar (a int) as (SELECT a FROM foo)
SELECT * FROM bar;
----
With Mutually Recursive
  cte [l0 as foo] =
    Distinct
      Union
        Map (1, 2)
          Constant
            - ()
        Map (7)
          Get l1
  cte [l1 as bar] =
    Project (#0)
      Get l0
Return
  Get l1

Target cluster: mz_catalog_server

EOF

