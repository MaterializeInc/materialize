# OFFSET clause in TopK
query T multiline
EXPLAIN RAW PLAN AS TEXT FOR
SELECT a+b, (SELECT a*b FROM t OFFSET 1)
FROM t;
----
Project (#2, #3)
  With
    cte [l1 as subquery-1] =
      Project (#2)
        TopK offset=1
          Map ((#0{a} * #1{b}))
            Get materialize.public.t
  Return
    Map ((#0{a} + #1{b}), select(Get l1))
      Get materialize.public.t

Target cluster: quickstart

EOF

