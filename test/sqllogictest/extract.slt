mode cockroach

statement ok
CREATE TABLE data (input text)

statement ok
INSERT INTO data VALUES
    ('asdfjkl'), ('foo'), ('asdf'), ('testing,123'),
    (NULL), ('jkl'), ('some,csv')

query TTT colnames
SELECT data.*, reg.*
FROM data, regexp_extract('(asdf)|(?P<foo>jkl)', data.input) reg
ORDER BY data.input
----
input    column1  foo
asdf     asdf     NULL
asdfjkl  asdf     NULL
jkl      NULL     jkl

query TTTI colnames
SELECT data.*, reg.*
FROM data, regexp_extract('(asdf)|(?P<foo>jkl)', data.input) reg WITH ORDINALITY
ORDER BY data.input
----
input    column1  foo   ordinality
asdf     asdf     NULL  1
asdfjkl  asdf     NULL  1
jkl      NULL     jkl   1

# Regression test for database-issues#612: capture-group columns now have
# precise nullability instead of always being nullable. A capture group is
# non-nullable iff it is guaranteed to participate in every match, i.e. it is
# not inside an alternation or a zero-matching repetition (`*`, `?`, `{0,n}`).
statement ok
CREATE VIEW regexp_nullability AS
SELECT reg.*
FROM data, regexp_extract('(?P<required>[0-9]+)-(?P<optional>[a-z]+)?-(?:(?P<alt_a>x)|(?P<alt_b>y))', data.input) reg

query ITT
SELECT c.position, c.name, c.nullable::text
    FROM mz_columns c
    JOIN mz_views v ON c.id = v.id
    WHERE v.name = 'regexp_nullability'
    ORDER BY c.position
----
1  required  false
2  optional  true
3  alt_a     true
4  alt_b     true

query TTT colnames
SELECT data.*, csv.* FROM data, csv_extract(2, data.input) csv
ORDER BY data.input
----
input        column1  column2
some,csv     some     csv
testing,123  testing  123

query error csv_extract number of columns must be a positive integer literal
SELECT * FROM data, (VALUES (2)) ncols, csv_extract(ncols.column1, data.input)

query error csv_extract number of columns must be a positive integer literal
SELECT * FROM data, csv_extract((SELECT 2), data.input)

query error attempt to create relation with too many columns, 8193 max: 8192
SELECT * FROM data, csv_extract(8193, data.input)

statement ok
SELECT * FROM data, csv_extract(8192, data.input)
