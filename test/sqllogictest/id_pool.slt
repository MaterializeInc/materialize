# Regression test for pre-allocated user ID pool.
# Exercises multiple DDL types to verify IDs are unique and objects
# function correctly when allocated from the pool.

mode cockroach

# Create a variety of object types to exercise pool allocation.

statement ok
CREATE TABLE id_pool_t1 (a INT)

statement ok
CREATE TABLE id_pool_t2 (b TEXT)

statement ok
CREATE TABLE id_pool_t3 (c BOOL)

statement ok
CREATE VIEW id_pool_v1 AS SELECT * FROM id_pool_t1

statement ok
CREATE VIEW id_pool_v2 AS SELECT * FROM id_pool_t2

statement ok
CREATE MATERIALIZED VIEW id_pool_mv1 AS SELECT count(*) FROM id_pool_t1

statement ok
CREATE DEFAULT INDEX ON id_pool_t2

statement ok
CREATE TYPE id_pool_ty1 AS LIST (ELEMENT TYPE = INT4)

statement ok
CREATE SECRET id_pool_secret AS 'sekret'

# Verify all objects exist and have unique IDs.
query I
SELECT count(DISTINCT id) FROM mz_objects WHERE name LIKE 'id_pool_%'
----
9

# Verify the objects are usable.

statement ok
INSERT INTO id_pool_t1 VALUES (1), (2), (3)

query I rowsort
SELECT * FROM id_pool_v1
----
1
2
3

query I
SELECT * FROM id_pool_mv1
----
3

# Drop and recreate to exercise pool across multiple rounds of allocation.

statement ok
DROP MATERIALIZED VIEW id_pool_mv1

statement ok
DROP VIEW id_pool_v1

statement ok
DROP VIEW id_pool_v2

statement ok
CREATE VIEW id_pool_v1_new AS SELECT a + 10 AS a FROM id_pool_t1

statement ok
CREATE MATERIALIZED VIEW id_pool_mv1_new AS SELECT count(*) FROM id_pool_t1

# Verify the new objects work and have unique IDs.
query I rowsort
SELECT * FROM id_pool_v1_new
----
11
12
13

query I
SELECT * FROM id_pool_mv1_new
----
3

# Check that recreated objects got fresh, unique IDs.
query I
SELECT count(DISTINCT id) FROM mz_objects WHERE name LIKE 'id_pool_%'
----
8

# Cleanup.

statement ok
DROP MATERIALIZED VIEW id_pool_mv1_new

statement ok
DROP VIEW id_pool_v1_new

statement ok
DROP SECRET id_pool_secret

statement ok
DROP TYPE id_pool_ty1

statement ok
DROP TABLE id_pool_t3

statement ok
DROP TABLE id_pool_t2 CASCADE

statement ok
DROP TABLE id_pool_t1
