query IT rowsort
SELECT COUNT(*), type
FROM
    mz_introspection.mz_dataflow_channel_operators mdco
    JOIN mz_introspection.mz_dataflow_operator_dataflows mdod
        ON mdco.from_operator_id = mdod.id
WHERE mdod.dataflow_name LIKE '%test_primary_idx'
GROUP BY type;
