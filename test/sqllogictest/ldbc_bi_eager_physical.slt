            project=(#0, #2, #3)
          source={ relation=0, key=[#1] }
        plan_path[1]
          delta_stage[1]
            closure
              project=(#0, #3, #4, #1)
            lookup={ relation=0, key=[#1] }
            stream={ key=[#0{creatorpersonid}], thinning=(#1) }
          delta_stage[0]
            closure
              project=(#1, #2)
            lookup={ relation=2, key=[#0] }
            stream={ key=[#0{creatorpersonid}], thinning=(#1) }
          initial_closure
            project=(#0, #9)
            filter=((#1{creationdate} <= 2012-11-24 00:00:00 UTC) AND (#1{creationdate} >= 2012-08-29 00:00:00 UTC) AND (#12{parentmessageid}) IS NULL)
