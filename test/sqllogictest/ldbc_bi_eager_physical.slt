# Goldens written by the equality-saturation optimizer, enabled here. The parent
# commit has these flags `false` (the production optimizer); the diff between the
# two commits is exactly eqsat's effect on the physical plans.
simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_eqsat_optimizer = true;
----
COMPLETE 0

simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_eqsat_physical_optimizer = true;
----
COMPLETE 0

simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_eqsat_ilp_extraction = true;
----
COMPLETE 0

# The underlying LDBC SNB BI benchmark is under the Apache 2.0 license
# as well; see materialize/test/ldbc-bi/LICENSE.txt.
#
# This is a variant that uses eager delta joins.

simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_eager_delta_joins = true
----
COMPLETE 0

