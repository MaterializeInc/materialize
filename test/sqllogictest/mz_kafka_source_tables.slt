# Behavioural tests for mz_internal.mz_kafka_source_tables. The view is a
# BuiltinMaterializedView backed by SQL over mz_internal.mz_catalog_raw: see
# MZ_KAFKA_SOURCE_TABLES in src/catalog/src/builtin/mz_internal.rs and the
# parse_source_export_details helper in
# src/expr/src/scalar/func/impls/jsonb.rs. Rows with real upstream data, and
# the envelope/format resolution, are exercised by test/testdrive/mz-sources.td;
# this file pins the column shape and the parent-type filtering that need no
# live Kafka.

mode cockroach

reset-server

# --- Schema -------------------------------------------------------------------

# Lock down: 5 columns, canonical order, types, and nullability.
query TTT
SELECT c.name, c.type, c.nullable::text
FROM mz_catalog.mz_columns c
JOIN mz_catalog.mz_objects o ON c.id = o.id
JOIN mz_catalog.mz_schemas s ON o.schema_id = s.id
WHERE o.name = 'mz_kafka_source_tables' AND s.name = 'mz_internal'
ORDER BY c.position
----
id  text  false
topic  text  false
envelope_type  text  true
key_format  text  true
value_format  text  true

# --- Empty on a fresh env -----------------------------------------------------

query I
SELECT count(*) FROM mz_internal.mz_kafka_source_tables
----
0

# --- Non-kafka exports are excluded -------------------------------------------

statement ok
CREATE SOURCE lg_src IN CLUSTER quickstart FROM LOAD GENERATOR AUCTION FOR ALL TABLES

query I
SELECT count(*) FROM mz_internal.mz_kafka_source_tables
----
0

# --- FK-like invariant --------------------------------------------------------

query I
SELECT count(*) FROM mz_internal.mz_kafka_source_tables kst
LEFT JOIN mz_sources s ON kst.id = s.id
LEFT JOIN mz_tables t ON kst.id = t.id
WHERE s.id IS NULL AND t.id IS NULL
----
0

statement ok
DROP SOURCE lg_src CASCADE
