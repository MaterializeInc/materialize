# Behavioural tests for mz_internal.mz_mysql_source_tables. The view is a
# BuiltinMaterializedView backed by SQL over mz_internal.mz_catalog_raw: see
# MZ_MYSQL_SOURCE_TABLES in src/catalog/src/builtin/mz_internal.rs and the
# parse_source_export_details helper in
# src/expr/src/scalar/func/impls/jsonb.rs. Rows with real upstream data are
# exercised by test/mysql-cdc; this file pins the column shape and the
# parent-type filtering that need no live MySQL.

mode cockroach

reset-server

# --- Schema -------------------------------------------------------------------

# Lock down: 3 columns, canonical order, types, and nullability.
query TTT
SELECT c.name, c.type, c.nullable::text
FROM mz_catalog.mz_columns c
JOIN mz_catalog.mz_objects o ON c.id = o.id
JOIN mz_catalog.mz_schemas s ON o.schema_id = s.id
WHERE o.name = 'mz_mysql_source_tables' AND s.name = 'mz_internal'
ORDER BY c.position
----
id  text  false
schema_name  text  false
table_name  text  false

# --- Empty on a fresh env -----------------------------------------------------

query I
SELECT count(*) FROM mz_internal.mz_mysql_source_tables
----
0

# --- Non-mysql exports are excluded -------------------------------------------

statement ok
CREATE SOURCE lg_src IN CLUSTER quickstart FROM LOAD GENERATOR AUCTION FOR ALL TABLES

query I
SELECT count(*) FROM mz_internal.mz_mysql_source_tables
----
0

# --- FK-like invariant --------------------------------------------------------

query I
SELECT count(*) FROM mz_internal.mz_mysql_source_tables mst
LEFT JOIN mz_sources s ON mst.id = s.id
LEFT JOIN mz_tables t ON mst.id = t.id
WHERE s.id IS NULL AND t.id IS NULL
----
0

statement ok
DROP SOURCE lg_src CASCADE
