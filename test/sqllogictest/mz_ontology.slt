# Smoke tests for the mz_ontology schema.

mode cockroach

simple conn=mz_system,user=mz_system
ALTER SYSTEM SET unsafe_enable_unstable_dependencies = true
----
COMPLETE 0

# Verify the four ontology tables exist and have the expected columns.

query TTTT
SELECT name, relation, properties->>'primary_key', description
FROM mz_ontology.mz_ontology_entity_types
WHERE name = 'cluster'
----
cluster  mz_catalog.mz_clusters  ["id"]  A‚ź†compute‚ź†cluster‚ź†that‚ź†runs‚ź†dataflows‚ź†for‚ź†sources,‚ź†sinks,‚ź†MVs,‚ź†and‚ź†indexes

query TTT
SELECT name, sql_type, description
FROM mz_ontology.mz_ontology_semantic_types
WHERE name = 'CatalogItemId'
----
CatalogItemId  text  SQL-layer‚ź†identifier‚ź†for‚ź†a‚ź†catalog‚ź†object‚ź†(table,‚ź†view,‚ź†MV,‚ź†source,‚ź†sink,‚ź†index,‚ź†connection,‚ź†secret,‚ź†type,‚ź†function).‚ź†Format:‚ź†s{n}/u{n}.‚ź†This‚ź†is‚ź†the‚ź†ID‚ź†users‚ź†see‚ź†in‚ź†mz_objects.id,‚ź†mz_tables.id,‚ź†etc.‚ź†Rust:‚ź†CatalogItemId‚ź†in‚ź†src/repr/src/catalog_item_id.rs

query TTTT
SELECT entity_type, column_name, semantic_type, description
FROM mz_ontology.mz_ontology_properties
WHERE entity_type = 'cluster' AND column_name = 'id'
----
cluster  id  ClusterId  Unique‚ź†cluster‚ź†identifier.‚ź†PK.

query TTTTT
SELECT name, source_entity, target_entity, properties->>'kind', description
FROM mz_ontology.mz_ontology_link_types
WHERE name = 'belongs_to_cluster' AND source_entity = 'replica'
----
belongs_to_cluster  replica  cluster  foreign_key  A‚ź†replica‚ź†belongs‚ź†to‚ź†exactly‚ź†one‚ź†cluster.‚ź†A‚ź†cluster‚ź†can‚ź†have‚ź†multiple‚ź†replicas.

# Verify basic row counts are in expected ranges.

query B
SELECT count(*) > 90 FROM mz_ontology.mz_ontology_entity_types
----
true

query B
SELECT count(*) >= 15 FROM mz_ontology.mz_ontology_semantic_types
----
true

query B
SELECT count(*) > 300 FROM mz_ontology.mz_ontology_properties
----
true

query B
SELECT count(*) > 80 FROM mz_ontology.mz_ontology_link_types
----
true

# Verify referential integrity: every entity_type in properties exists in entity_types.

query I
SELECT count(*)
FROM mz_ontology.mz_ontology_properties p
WHERE NOT EXISTS (
    SELECT 1 FROM mz_ontology.mz_ontology_entity_types e
    WHERE e.name = p.entity_type
)
----
0

# Verify referential integrity: every semantic_type in properties exists in semantic_types.

query I
SELECT count(*)
FROM mz_ontology.mz_ontology_properties p
WHERE p.semantic_type IS NOT NULL
  AND NOT EXISTS (
    SELECT 1 FROM mz_ontology.mz_ontology_semantic_types s
    WHERE s.name = p.semantic_type
)
----
0

# Verify referential integrity: link type source/target entities exist in entity_types.

query I
SELECT count(*)
FROM mz_ontology.mz_ontology_link_types l
WHERE NOT EXISTS (
    SELECT 1 FROM mz_ontology.mz_ontology_entity_types e
    WHERE e.name = l.source_entity
)
----
0

query I
SELECT count(*)
FROM mz_ontology.mz_ontology_link_types l
WHERE NOT EXISTS (
    SELECT 1 FROM mz_ontology.mz_ontology_entity_types e
    WHERE e.name = l.target_entity
)
----
0
