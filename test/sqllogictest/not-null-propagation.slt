#
# NULLIF is NOT NULL if first argument is NOT NULL, second argument is NULL, NULL-able otherwise
#


query T multiline
EXPLAIN OPTIMIZED PLAN WITH(types, no fast path, humanized expressions) AS VERBOSE TEXT FOR SELECT NULLIF(col_not_null, 'a') , NULLIF(col_not_null, NULL), NULLIF(col_null, NULL) , NULLIF(col_null, col_not_null) FROM int_table;
----
Explained Query:
  Project (#3, #1{col_not_null}, #0{col_null}, #2) // { types: "(rint32?, rint32, rint32?, rint32?)" }
    Map (case when (#0{col_null} = #1{col_not_null}) then null else #0{col_null} end, error("invalid input syntax for type integer: invalid digit found in string: \"a\"")) // { types: "(rint32?, rint32, rint32?, rint32?)" }
      ReadStorage materialize.public.int_table // { types: "(rint32?, rint32)" }

Source materialize.public.int_table

Target cluster: quickstart

Notices:
  - Notice: Comparison with NULL using `=`, `<>`, or `!=` always evaluates to NULL.
    Hint: Use `IS NULL` or `IS NOT NULL` instead.

