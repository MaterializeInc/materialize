#
# MIN/MAX/AVG/.. can be NULL even on a NOT NULL column
#

query T multiline
EXPLAIN OPTIMIZED PLAN WITH(types, no fast path, humanized expressions) AS VERBOSE TEXT FOR SELECT MIN(col_not_null), MAX(col_not_null), AVG(col_not_null), STDDEV(col_not_null), LIST_AGG(col_not_null) FROM int_table;
----
Explained Query:
  With
    cte l0 =
      Project (#1{col_not_null}) // { types: "(rint32)" }
        ReadStorage materialize.public.int_table // { types: "(rint32?, rint32)" }
    cte l1 =
      CrossJoin type=delta // { types: "(rint32, rint32, rint64, rint64, rnumeric, rnumeric, rint64, rlist(rint32))" }
        ArrangeBy keys=[[]] // { types: "(rint32, rint32)" }
          Reduce aggregates=[min(#0{col_not_null}), max(#0{col_not_null})] // { types: "(rint32, rint32)" }
            Get l0 // { types: "(rint32)" }
        ArrangeBy keys=[[]] // { types: "(rint64, rint64, rnumeric, rnumeric, rint64)" }
          Reduce aggregates=[sum(#0{col_not_null}), count(*), sum((integer_to_numeric(#0{col_not_null}) * integer_to_numeric(#0{col_not_null}))), sum(integer_to_numeric(#0{col_not_null})), count(integer_to_numeric(#0{col_not_null}))] // { types: "(rint64, rint64, rnumeric, rnumeric, rint64)" }
            Get l0 // { types: "(rint32)" }
        ArrangeBy keys=[[]] // { types: "(rlist(rint32))" }
          Reduce aggregates=[list_agg[order_by=[]](row(list[#0{col_not_null}]))] // { types: "(rlist(rint32))" }
            Get l0 // { types: "(rint32)" }
  Return // { types: "(rint32?, rint32?, rnumeric?, rnumeric?, rlist(rint32)?)" }
    Project (#0{min_col_not_null}, #1{max_col_not_null}, #8, #9, #7{list_agg}) // { types: "(rint32?, rint32?, rnumeric?, rnumeric?, rlist(rint32)?)" }
      Map ((bigint_to_numeric(#2{sum_col_not_null}) / bigint_to_numeric(case when (#3{count} = 0) then null else #3{count} end)), sqrtnumeric(case when ((#4{sum}) IS NULL OR (#5{sum}) IS NULL OR (case when (#6{count} = 0) then null else #6{count} end) IS NULL OR (case when (0 = (#6{count} - 1)) then null else (#6{count} - 1) end) IS NULL) then null else greatest(((#4{sum} - ((#5{sum} * #5{sum}) / bigint_to_numeric(case when (#6{count} = 0) then null else #6{count} end))) / bigint_to_numeric(case when (0 = (#6{count} - 1)) then null else (#6{count} - 1) end)), 0) end)) // { types: "(rint32?, rint32?, rint64?, rint64, rnumeric?, rnumeric?, rint64, rlist(rint32)?, rnumeric?, rnumeric?)" }
        Union // { types: "(rint32?, rint32?, rint64?, rint64, rnumeric?, rnumeric?, rint64, rlist(rint32)?)" }
          Get l1 // { types: "(rint32, rint32, rint64, rint64, rnumeric, rnumeric, rint64, rlist(rint32))" }
          Map (null, null, null, 0, null, null, 0, null) // { types: "(rint32?, rint32?, rint64?, rint64, rnumeric?, rnumeric?, rint64, rlist(rint32)?)" }
            Union // { types: "()" }
              Negate // { types: "()" }
                Project () // { types: "()" }
                  Get l1 // { types: "(rint32, rint32, rint64, rint64, rnumeric, rnumeric, rint64, rlist(rint32))" }
              Constant // { types: "()" }
                - ()

Source materialize.public.int_table

Target cluster: quickstart

