  With
    cte l0 =
      Distinct project=[#0{col_null}, #1{col_not_null}] // { types: "(rint32?, rint32)" }
        ReadStorage materialize.public.int_table // { types: "(rint32?, rint32)" }
  Return // { types: "(rbool?, rbool, rbool?, rbool?, rbool?, rbool?)" }
    Project (#5, #4, #7, #8, #6, #6) // { types: "(rbool?, rbool, rbool?, rbool?, rbool?, rbool?)" }
      Map ((#0{col_null} = 1), (#0{col_null} = #1{col_not_null}), null, null) // { types: "(rint32?, rint32, rint32?, rint32, rbool, rbool?, rbool?, rbool?, rbool?)" }
        Join on=(#0{col_null} = #2{col_null} AND #1{col_not_null} = #3{col_not_null}) type=differential // { types: "(rint32?, rint32, rint32?, rint32, rbool)" }
          ArrangeBy keys=[[#0{col_null}, #1{col_not_null}]] // { types: "(rint32?, rint32)" }
            ReadStorage materialize.public.int_table // { types: "(rint32?, rint32)" }
          ArrangeBy keys=[[#0{col_null}, #1{col_not_null}]] // { types: "(rint32?, rint32, rbool)" }
            Union // { types: "(rint32?, rint32, rbool)" }
              Filter (#1{col_not_null} = 1) // { types: "(rint32?, rint32, rbool)" }
