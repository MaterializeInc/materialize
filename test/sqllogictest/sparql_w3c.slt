# W3C SPARQL 1.1 Compliance Test Suite
#
# Tests ported from the W3C SPARQL 1.1 test suite
# (https://www.w3.org/2009/sparql/docs/tests/) into sqllogictest format.
#
# Each section corresponds to a W3C test category. Tests exercise the
# full SPARQL pipeline: SQL parser → SPARQL parser → planner → HIR → MIR → execution.

mode cockroach

# =============================================================================
# Setup: Create quad table and load a small RDF dataset
# =============================================================================

statement ok
CREATE TABLE rdf_quads (subject TEXT, predicate TEXT, object TEXT, graph TEXT)

# -- People (types) --
statement ok
INSERT INTO rdf_quads VALUES
  ('<http://example.org/alice>', '<http://www.w3.org/1999/02/22-rdf-syntax-ns#type>', '<http://xmlns.com/foaf/0.1/Person>', '<http://example.org/default>'),
  ('<http://example.org/bob>', '<http://www.w3.org/1999/02/22-rdf-syntax-ns#type>', '<http://xmlns.com/foaf/0.1/Person>', '<http://example.org/default>'),
  ('<http://example.org/carol>', '<http://www.w3.org/1999/02/22-rdf-syntax-ns#type>', '<http://xmlns.com/foaf/0.1/Person>', '<http://example.org/default>'),
  ('<http://example.org/dave>', '<http://www.w3.org/1999/02/22-rdf-syntax-ns#type>', '<http://xmlns.com/foaf/0.1/Person>', '<http://example.org/default>')

# -- Names --
statement ok
INSERT INTO rdf_quads VALUES
  ('<http://example.org/alice>', '<http://xmlns.com/foaf/0.1/name>', '"Alice"', '<http://example.org/default>'),
  ('<http://example.org/bob>', '<http://xmlns.com/foaf/0.1/name>', '"Bob"', '<http://example.org/default>'),
  ('<http://example.org/carol>', '<http://xmlns.com/foaf/0.1/name>', '"Carol"', '<http://example.org/default>'),
  ('<http://example.org/dave>', '<http://xmlns.com/foaf/0.1/name>', '"Dave"', '<http://example.org/default>')

# -- Ages (typed literals) --
statement ok
INSERT INTO rdf_quads VALUES
  ('<http://example.org/alice>', '<http://xmlns.com/foaf/0.1/age>', '"30"^^<http://www.w3.org/2001/XMLSchema#integer>', '<http://example.org/default>'),
  ('<http://example.org/bob>', '<http://xmlns.com/foaf/0.1/age>', '"25"^^<http://www.w3.org/2001/XMLSchema#integer>', '<http://example.org/default>'),
  ('<http://example.org/carol>', '<http://xmlns.com/foaf/0.1/age>', '"35"^^<http://www.w3.org/2001/XMLSchema#integer>', '<http://example.org/default>')

# -- Email (only some people) --
statement ok
INSERT INTO rdf_quads VALUES
  ('<http://example.org/alice>', '<http://xmlns.com/foaf/0.1/mbox>', '"alice@example.org"', '<http://example.org/default>'),
  ('<http://example.org/bob>', '<http://xmlns.com/foaf/0.1/mbox>', '"bob@example.org"', '<http://example.org/default>')

# -- Knows relationships --
statement ok
INSERT INTO rdf_quads VALUES
  ('<http://example.org/alice>', '<http://xmlns.com/foaf/0.1/knows>', '<http://example.org/bob>', '<http://example.org/default>'),
  ('<http://example.org/bob>', '<http://xmlns.com/foaf/0.1/knows>', '<http://example.org/carol>', '<http://example.org/default>'),
  ('<http://example.org/carol>', '<http://xmlns.com/foaf/0.1/knows>', '<http://example.org/dave>', '<http://example.org/default>')

# -- Interests --
statement ok
INSERT INTO rdf_quads VALUES
  ('<http://example.org/alice>', '<http://xmlns.com/foaf/0.1/interest>', '"Databases"', '<http://example.org/default>'),
  ('<http://example.org/alice>', '<http://xmlns.com/foaf/0.1/interest>', '"SPARQL"', '<http://example.org/default>'),
  ('<http://example.org/bob>', '<http://xmlns.com/foaf/0.1/interest>', '"Music"', '<http://example.org/default>')

# -- Language-tagged literals --
statement ok
INSERT INTO rdf_quads VALUES
  ('<http://example.org/alice>', '<http://www.w3.org/2000/01/rdf-schema#label>', '"Alice"@en', '<http://example.org/default>'),
  ('<http://example.org/alice>', '<http://www.w3.org/2000/01/rdf-schema#label>', '"Alicia"@es', '<http://example.org/default>')

# -- Class hierarchy for property path tests --
statement ok
INSERT INTO rdf_quads VALUES
  ('<http://example.org/Dog>', '<http://www.w3.org/2000/01/rdf-schema#subClassOf>', '<http://example.org/Animal>', '<http://example.org/default>'),
  ('<http://example.org/Cat>', '<http://www.w3.org/2000/01/rdf-schema#subClassOf>', '<http://example.org/Animal>', '<http://example.org/default>'),
  ('<http://example.org/Animal>', '<http://www.w3.org/2000/01/rdf-schema#subClassOf>', '<http://example.org/LivingThing>', '<http://example.org/default>'),
  ('<http://example.org/LivingThing>', '<http://www.w3.org/2000/01/rdf-schema#subClassOf>', '<http://example.org/Thing>', '<http://example.org/default>')

# -- Second named graph for GRAPH/FROM tests --
statement ok
INSERT INTO rdf_quads VALUES
  ('<http://example.org/alice>', '<http://xmlns.com/foaf/0.1/name>', '"Alice Smith"', '<http://example.org/graph2>'),
  ('<http://example.org/alice>', '<http://xmlns.com/foaf/0.1/nick>', '"ally"', '<http://example.org/graph2>')

# =============================================================================
# Section 1: Basic Graph Patterns (W3C dawg-triple-pattern)
# =============================================================================

# W3C test: dawg-tp-01 — single triple, all variables
query TTT colnames
SPARQL $$ SELECT ?s ?p ?o WHERE { ?s ?p ?o } ORDER BY ?s ?p ?o LIMIT 5 $$
----
s  p  o
<http://example.org/Cat>  <http://www.w3.org/2000/01/rdf-schema#subClassOf>  <http://example.org/Animal>
<http://example.org/Dog>  <http://www.w3.org/2000/01/rdf-schema#subClassOf>  <http://example.org/Animal>
<http://example.org/LivingThing>  <http://www.w3.org/2000/01/rdf-schema#subClassOf>  <http://example.org/Thing>
<http://example.org/alice>  <http://www.w3.org/2000/01/rdf-schema#label>  "Alice"@en
<http://example.org/alice>  <http://www.w3.org/2000/01/rdf-schema#label>  "Alicia"@es

# W3C test: dawg-tp-02 — concrete predicate
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s ?name
  WHERE { ?s foaf:name ?name }
  ORDER BY ?name
$$
----
s  name
<http://example.org/alice>  "Alice"
<http://example.org/bob>  "Bob"
<http://example.org/carol>  "Carol"
<http://example.org/dave>  "Dave"

# W3C test: dawg-tp-03 — concrete subject and predicate
query T colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name
  WHERE { <http://example.org/alice> foaf:name ?name }
$$
----
name
"Alice"

# W3C test: dawg-tp-04 — multi-triple BGP with shared variable
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s ?name
  WHERE {
    ?s a foaf:Person .
    ?s foaf:name ?name .
  }
  ORDER BY ?name
$$
----
s  name
<http://example.org/alice>  "Alice"
<http://example.org/bob>  "Bob"
<http://example.org/carol>  "Carol"
<http://example.org/dave>  "Dave"

# W3C test: dawg-tp-05 — three-way join
query TTT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?person ?name ?friend
  WHERE {
    ?person foaf:name ?name .
    ?person foaf:knows ?friend .
  }
  ORDER BY ?name
$$
----
person  name  friend
<http://example.org/alice>  "Alice"  <http://example.org/bob>
<http://example.org/bob>  "Bob"  <http://example.org/carol>
<http://example.org/carol>  "Carol"  <http://example.org/dave>

# =============================================================================
# Section 2: FILTER (W3C dawg-filter)
# =============================================================================

# W3C test: dawg-filter-eq — string equality
query T colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s
  WHERE {
    ?s foaf:name ?name .
    FILTER(?name = "Alice")
  }
$$
----
s
<http://example.org/alice>

# W3C test: dawg-filter-inequality — numeric comparison
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s ?age
  WHERE {
    ?s foaf:age ?age .
    FILTER(?age > 28)
  }
  ORDER BY ?s
$$
----
s  age
<http://example.org/alice>  "30"^^<http://www.w3.org/2001/XMLSchema#integer>
<http://example.org/carol>  "35"^^<http://www.w3.org/2001/XMLSchema#integer>

# W3C test: dawg-filter-and — logical AND
query T colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s
  WHERE {
    ?s foaf:age ?age .
    ?s foaf:name ?name .
    FILTER(?age > 28 && ?name != "Carol")
  }
$$
----
s
<http://example.org/alice>

# W3C test: dawg-filter-or — logical OR
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s ?name
  WHERE {
    ?s foaf:name ?name .
    ?s foaf:age ?age .
    FILTER(?age < 26 || ?age > 34)
  }
  ORDER BY ?name
$$
----
s  name
<http://example.org/bob>  "Bob"
<http://example.org/carol>  "Carol"

# W3C test: dawg-filter-not — logical NOT
query T colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name
  WHERE {
    ?s foaf:name ?name .
    ?s foaf:age ?age .
    FILTER(!(?age > 30))
  }
  ORDER BY ?name
$$
----
name
"Alice"
"Bob"

# W3C test: dawg-filter-bound — BOUND function
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s ?mbox
  WHERE {
    ?s foaf:name ?name .
    OPTIONAL { ?s foaf:mbox ?mbox }
    FILTER(BOUND(?mbox))
  }
  ORDER BY ?s
$$
----
s  mbox
<http://example.org/alice>  "alice@example.org"
<http://example.org/bob>  "bob@example.org"

# W3C test: dawg-filter-not-bound — negated BOUND
query T colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s
  WHERE {
    ?s foaf:name ?name .
    OPTIONAL { ?s foaf:mbox ?mbox }
    FILTER(!BOUND(?mbox))
  }
  ORDER BY ?s
$$
----
s
<http://example.org/carol>
<http://example.org/dave>

# =============================================================================
# Section 3: OPTIONAL (W3C dawg-optional)
# =============================================================================

# W3C test: dawg-optional-001 — basic OPTIONAL
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name ?mbox
  WHERE {
    ?s foaf:name ?name .
    OPTIONAL { ?s foaf:mbox ?mbox }
  }
  ORDER BY ?name
$$
----
name  mbox
"Alice"  "alice@example.org"
"Bob"  "bob@example.org"
"Carol"  NULL
"Dave"  NULL

# W3C test: dawg-optional-002 — OPTIONAL with FILTER inside
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name ?age
  WHERE {
    ?s foaf:name ?name .
    OPTIONAL {
      ?s foaf:age ?age .
      FILTER(?age > 28)
    }
  }
  ORDER BY ?name
$$
----
name  age
"Alice"  "30"^^<http://www.w3.org/2001/XMLSchema#integer>
"Bob"  NULL
"Carol"  "35"^^<http://www.w3.org/2001/XMLSchema#integer>
"Dave"  NULL

# W3C test: dawg-optional-003 — multiple OPTIONALs
query TTT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name ?age ?mbox
  WHERE {
    ?s foaf:name ?name .
    OPTIONAL { ?s foaf:age ?age }
    OPTIONAL { ?s foaf:mbox ?mbox }
  }
  ORDER BY ?name
$$
----
name  age  mbox
"Alice"  "30"^^<http://www.w3.org/2001/XMLSchema#integer>  "alice@example.org"
"Bob"  "25"^^<http://www.w3.org/2001/XMLSchema#integer>  "bob@example.org"
"Carol"  "35"^^<http://www.w3.org/2001/XMLSchema#integer>  NULL
"Dave"  NULL  NULL

# =============================================================================
# Section 4: UNION (W3C dawg-union)
# =============================================================================

# W3C test: union-1 — basic UNION
query T colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?contact
  WHERE {
    { ?s foaf:name ?contact }
    UNION
    { ?s foaf:mbox ?contact }
  }
  ORDER BY ?contact
$$
----
contact
"Alice"
"Bob"
"Carol"
"Dave"
"alice@example.org"
"bob@example.org"

# W3C test: union-2 — UNION with different variables
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name ?mbox
  WHERE {
    { ?s foaf:name ?name }
    UNION
    { ?s foaf:mbox ?mbox }
  }
  ORDER BY ?name ?mbox
$$
----
name  mbox
"Alice"  NULL
"Bob"  NULL
"Carol"  NULL
"Dave"  NULL
NULL  "alice@example.org"
NULL  "bob@example.org"

# =============================================================================
# Section 5: MINUS (W3C dawg-minus)
# =============================================================================

# W3C test: minus-1 — basic MINUS
query T colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s
  WHERE {
    ?s a foaf:Person .
    MINUS { ?s foaf:mbox ?mbox }
  }
  ORDER BY ?s
$$
----
s
<http://example.org/carol>
<http://example.org/dave>

# W3C test: minus-2 — MINUS with no shared variables (no rows removed)
query I colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT (COUNT(?s) AS ?count)
  WHERE {
    ?s a foaf:Person .
    MINUS { ?x foaf:interest ?i }
  }
$$
----
count
4

# =============================================================================
# Section 6: NOT EXISTS (W3C dawg-negation)
# =============================================================================

# W3C test: exists-01 — FILTER NOT EXISTS
query T colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s
  WHERE {
    ?s a foaf:Person .
    FILTER NOT EXISTS { ?s foaf:mbox ?mbox }
  }
  ORDER BY ?s
$$
----
s
<http://example.org/carol>
<http://example.org/dave>

# W3C test: exists-02 — FILTER EXISTS
query T colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s
  WHERE {
    ?s a foaf:Person .
    FILTER EXISTS { ?s foaf:knows ?friend }
  }
  ORDER BY ?s
$$
----
s
<http://example.org/alice>
<http://example.org/bob>
<http://example.org/carol>

# =============================================================================
# Section 7: BIND (W3C dawg-bind)
# =============================================================================

# W3C test: bind-01 — basic BIND
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name ?greeting
  WHERE {
    ?s foaf:name ?name .
    BIND(CONCAT("Hello, ", ?name) AS ?greeting)
  }
  ORDER BY ?name
  LIMIT 2
$$
----
name  greeting
"Alice"  Hello, "Alice"
"Bob"  Hello, "Bob"

# W3C test: bind-02 — BIND with IF
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name ?category
  WHERE {
    ?s foaf:name ?name .
    ?s foaf:age ?age .
    BIND(IF(?age > 29, "senior", "junior") AS ?category)
  }
  ORDER BY ?name
$$
----
name  category
"Alice"  senior
"Bob"  junior
"Carol"  senior

# =============================================================================
# Section 8: VALUES (W3C dawg-values)
# =============================================================================

# W3C test: values-01 — inline VALUES
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s ?name
  WHERE {
    VALUES ?s { <http://example.org/alice> <http://example.org/bob> }
    ?s foaf:name ?name .
  }
  ORDER BY ?name
$$
----
s  name
<http://example.org/alice>  "Alice"
<http://example.org/bob>  "Bob"

# =============================================================================
# Section 9: Property Paths (W3C dawg-property-path)
# =============================================================================

# W3C test: pp-01 — inverse path
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s ?knower
  WHERE {
    ?s ^foaf:knows ?knower .
    ?s foaf:name ?sname .
  }
  ORDER BY ?sname
$$
----
s  knower
<http://example.org/alice>  <http://example.org/bob>
<http://example.org/bob>  <http://example.org/carol>
<http://example.org/carol>  <http://example.org/dave>

# W3C test: pp-02 — sequence path
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?person ?friendName
  WHERE {
    ?person foaf:knows/foaf:name ?friendName .
  }
  ORDER BY ?friendName
$$
----
person  friendName
<http://example.org/bob>  "Carol"
<http://example.org/carol>  "Dave"

# We skip the test below because foaf:name is not a valid start for foaf:knows
# (alice→bob path: alice knows bob, bob has name "Bob")
# But let's do the simple version: alice knows/name → "Bob"
query T colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?friendName
  WHERE {
    <http://example.org/alice> foaf:knows/foaf:name ?friendName .
  }
$$
----
friendName
"Bob"

# W3C test: pp-03 — alternative path
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s ?val
  WHERE {
    ?s (foaf:name|foaf:mbox) ?val .
  }
  ORDER BY ?s ?val
  LIMIT 6
$$
----
s  val
<http://example.org/alice>  "Alice"
<http://example.org/alice>  "alice@example.org"
<http://example.org/bob>  "Bob"
<http://example.org/bob>  "bob@example.org"
<http://example.org/carol>  "Carol"
<http://example.org/dave>  "Dave"

# W3C test: pp-04 — transitive closure (one-or-more)
query TT colnames
SPARQL $$
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  SELECT ?sub ?super
  WHERE {
    ?sub rdfs:subClassOf+ ?super .
  }
  ORDER BY ?sub ?super
$$
----
sub  super
<http://example.org/Animal>  <http://example.org/LivingThing>
<http://example.org/Animal>  <http://example.org/Thing>
<http://example.org/Cat>  <http://example.org/Animal>
<http://example.org/Cat>  <http://example.org/LivingThing>
<http://example.org/Cat>  <http://example.org/Thing>
<http://example.org/Dog>  <http://example.org/Animal>
<http://example.org/Dog>  <http://example.org/LivingThing>
<http://example.org/Dog>  <http://example.org/Thing>
<http://example.org/LivingThing>  <http://example.org/Thing>

# W3C test: pp-05 — zero-or-one path
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?start ?end
  WHERE {
    <http://example.org/alice> foaf:knows? ?end .
  }
  ORDER BY ?end
$$
----
start  end
NULL  <http://example.org/alice>
NULL  <http://example.org/bob>

# W3C test: pp-06 — transitive knows chain (one-or-more)
query T colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?reachable
  WHERE {
    <http://example.org/alice> foaf:knows+ ?reachable .
  }
  ORDER BY ?reachable
$$
----
reachable
<http://example.org/bob>
<http://example.org/carol>
<http://example.org/dave>

# W3C test: pp-07 — negated property set
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  SELECT ?s ?o
  WHERE {
    <http://example.org/alice> !(foaf:name|rdf:type) ?o .
  }
  ORDER BY ?o
$$
----
s  o
NULL  "30"^^<http://www.w3.org/2001/XMLSchema#integer>
NULL  "Alice"@en
NULL  "Alicia"@es
NULL  "Databases"
NULL  "SPARQL"
NULL  "alice@example.org"
NULL  <http://example.org/bob>

# =============================================================================
# Section 10: Aggregates (W3C dawg-aggregates)
# =============================================================================

# W3C test: agg-01 — COUNT
query I colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT (COUNT(?s) AS ?count)
  WHERE { ?s a foaf:Person }
$$
----
count
4

# W3C test: agg-02 — GROUP BY + COUNT
query TI colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?type (COUNT(?s) AS ?count)
  WHERE { ?s a ?type }
  GROUP BY ?type
  ORDER BY ?type
$$
----
type  count
<http://xmlns.com/foaf/0.1/Person>  4

# W3C test: agg-03 — SUM
query T colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT (SUM(?age) AS ?total)
  WHERE { ?s foaf:age ?age }
$$
----
total
90

# W3C test: agg-04 — MIN / MAX
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT (MIN(?age) AS ?youngest) (MAX(?age) AS ?oldest)
  WHERE { ?s foaf:age ?age }
$$
----
youngest  oldest
25  35

# W3C test: agg-05 — COUNT with GROUP BY + HAVING
query TI colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s (COUNT(?i) AS ?interests)
  WHERE { ?s foaf:interest ?i }
  GROUP BY ?s
  HAVING (COUNT(?i) > 1)
$$
----
s  interests
<http://example.org/alice>  2

# W3C test: agg-06 — COUNT DISTINCT
query I colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT (COUNT(DISTINCT ?type) AS ?types)
  WHERE { ?s a ?type }
$$
----
types
1

# =============================================================================
# Section 11: Solution Modifiers (W3C dawg-solution-modifiers)
# =============================================================================

# W3C test: limit-1 — LIMIT
query T colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name
  WHERE { ?s foaf:name ?name }
  ORDER BY ?name
  LIMIT 2
$$
----
name
"Alice"
"Bob"

# W3C test: offset-1 — OFFSET
query T colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name
  WHERE { ?s foaf:name ?name }
  ORDER BY ?name
  LIMIT 2 OFFSET 2
$$
----
name
"Carol"
"Dave"

# W3C test: order-1 — ORDER BY DESC
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name ?age
  WHERE {
    ?s foaf:name ?name .
    ?s foaf:age ?age .
  }
  ORDER BY DESC(?age)
$$
----
name  age
"Carol"  "35"^^<http://www.w3.org/2001/XMLSchema#integer>
"Alice"  "30"^^<http://www.w3.org/2001/XMLSchema#integer>
"Bob"  "25"^^<http://www.w3.org/2001/XMLSchema#integer>

# W3C test: distinct-1 — DISTINCT
query T colnames
SPARQL $$
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  SELECT DISTINCT ?type
  WHERE { ?s rdf:type ?type }
$$
----
type
<http://xmlns.com/foaf/0.1/Person>

# =============================================================================
# Section 12: CONSTRUCT (W3C dawg-construct)
# =============================================================================

# W3C test: construct-1 — basic CONSTRUCT
query TTT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  PREFIX ex: <http://example.org/>
  CONSTRUCT {
    ?s ex:hasName ?name .
  }
  WHERE {
    ?s foaf:name ?name .
  }
  ORDER BY ?name
  LIMIT 2
$$
----
subject  predicate  object
<http://example.org/alice>  <http://example.org/hasName>  "Alice"
<http://example.org/bob>  <http://example.org/hasName>  "Bob"

# =============================================================================
# Section 13: ASK (W3C dawg-ask)
# =============================================================================

# W3C test: ask-1 — positive ASK
query T colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  ASK { <http://example.org/alice> foaf:name "Alice" }
$$
----
result
true

# W3C test: ask-2 — negative ASK
query T colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  ASK { <http://example.org/alice> foaf:name "NotAlice" }
$$
----
result
false

# =============================================================================
# Section 14: SELECT Expressions (W3C dawg-project-expression)
# =============================================================================

# W3C test: expr-01 — UCASE
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name (UCASE(?name) AS ?upper)
  WHERE { ?s foaf:name ?name }
  ORDER BY ?name
  LIMIT 2
$$
----
name  upper
"Alice"  "ALICE"
"Bob"  "BOB"

# W3C test: expr-02 — CONCAT
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name (CONCAT(?name, " - person") AS ?desc)
  WHERE { ?s foaf:name ?name }
  ORDER BY ?name
  LIMIT 2
$$
----
name  desc
"Alice"  "Alice" - person
"Bob"  "Bob" - person

# W3C test: expr-03 — STRLEN
query TI colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name (STRLEN(?name) AS ?len)
  WHERE { ?s foaf:name ?name }
  ORDER BY ?name
$$
----
name  len
"Alice"  7
"Bob"  5
"Carol"  7
"Dave"  6

# W3C test: expr-04 — COALESCE
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name (COALESCE(?mbox, "no-email") AS ?email)
  WHERE {
    ?s foaf:name ?name .
    OPTIONAL { ?s foaf:mbox ?mbox }
  }
  ORDER BY ?name
$$
----
name  email
"Alice"  "alice@example.org"
"Bob"  "bob@example.org"
"Carol"  no-email
"Dave"  no-email

# W3C test: expr-05 — IF
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name (IF(BOUND(?mbox), "has-email", "no-email") AS ?status)
  WHERE {
    ?s foaf:name ?name .
    OPTIONAL { ?s foaf:mbox ?mbox }
  }
  ORDER BY ?name
$$
----
name  status
"Alice"  has-email
"Bob"  has-email
"Carol"  no-email
"Dave"  no-email

# =============================================================================
# Section 15: Type Testing Functions (W3C dawg-functions)
# =============================================================================

# W3C test: isIRI-01
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s (ISIRI(?s) AS ?is_iri)
  WHERE { ?s foaf:name "Alice" }
$$
----
s  is_iri
<http://example.org/alice>  true

# W3C test: isLiteral-01
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name (ISLITERAL(?name) AS ?is_lit)
  WHERE { <http://example.org/alice> foaf:name ?name }
$$
----
name  is_lit
"Alice"  true

# =============================================================================
# Section 16: Three-Valued Logic (W3C dawg-eval)
# =============================================================================

# W3C test: open-eq-01 — error in FILTER evaluates to false
# Comparing a string to a number should not error, just filter out
query I colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT (COUNT(?s) AS ?count)
  WHERE {
    ?s foaf:name ?name .
    FILTER(?name > 42)
  }
$$
----
count
0

# =============================================================================
# Section 17: Subqueries (W3C dawg-subquery)
# =============================================================================

# W3C test: subquery-01 — subquery with LIMIT
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name ?age
  WHERE {
    {
      SELECT ?s ?age
      WHERE { ?s foaf:age ?age }
      ORDER BY ?age
      LIMIT 2
    }
    ?s foaf:name ?name .
  }
  ORDER BY ?name
$$
----
name  age
"Alice"  "30"^^<http://www.w3.org/2001/XMLSchema#integer>
"Bob"  "25"^^<http://www.w3.org/2001/XMLSchema#integer>

# =============================================================================
# Section 18: Combined / Complex Queries
# =============================================================================

# Complex-01: OPTIONAL + FILTER + ORDER BY + LIMIT
query TTT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?name ?age ?mbox
  WHERE {
    ?s foaf:name ?name .
    OPTIONAL { ?s foaf:age ?age }
    OPTIONAL { ?s foaf:mbox ?mbox }
    FILTER(!BOUND(?age) || ?age > 25)
  }
  ORDER BY ?name
  LIMIT 3
$$
----
name  age  mbox
"Alice"  "30"^^<http://www.w3.org/2001/XMLSchema#integer>  "alice@example.org"
"Carol"  "35"^^<http://www.w3.org/2001/XMLSchema#integer>  NULL
"Dave"  NULL  NULL

# Complex-02: Property path + BGP join + aggregate
query TI colnames
SPARQL $$
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  SELECT ?super (COUNT(?sub) AS ?descendants)
  WHERE {
    ?sub rdfs:subClassOf+ ?super .
  }
  GROUP BY ?super
  ORDER BY DESC(?descendants)
$$
----
super  descendants
<http://example.org/Thing>  4
<http://example.org/LivingThing>  3
<http://example.org/Animal>  2

# Complex-03: UNION + OPTIONAL + FILTER NOT EXISTS
query TT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s ?contact
  WHERE {
    ?s a foaf:Person .
    FILTER NOT EXISTS { ?s foaf:knows ?someone }
    {
      { ?s foaf:name ?contact }
      UNION
      { ?s foaf:mbox ?contact }
    }
  }
  ORDER BY ?contact
$$
----
s  contact
<http://example.org/dave>  "Dave"

# Complex-04: BIND + VALUES + FILTER
query TTT colnames
SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?s ?name ?label
  WHERE {
    VALUES ?s { <http://example.org/alice> <http://example.org/carol> }
    ?s foaf:name ?name .
    BIND(CONCAT("Person: ", ?name) AS ?label)
  }
  ORDER BY ?name
$$
----
s  name  label
<http://example.org/alice>  "Alice"  Person: "Alice"
<http://example.org/carol>  "Carol"  Person: "Carol"

# =============================================================================
# Section 19: CREATE VIEW from SPARQL
# =============================================================================

statement ok
CREATE VIEW sparql_people AS SPARQL $$
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  SELECT ?person ?name
  WHERE {
    ?person a foaf:Person .
    ?person foaf:name ?name .
  }
$$

query TT colnames
SELECT * FROM sparql_people ORDER BY name
----
person  name
<http://example.org/alice>  "Alice"
<http://example.org/bob>  "Bob"
<http://example.org/carol>  "Carol"
<http://example.org/dave>  "Dave"

statement ok
DROP VIEW sparql_people

