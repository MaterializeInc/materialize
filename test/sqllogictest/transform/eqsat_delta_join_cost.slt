mode cockroach

# ============================================================================
# eqsat physical join commit on the variable-outer-join (VOJ) case.
#
# The query is a chain of LEFT JOINs whose second join key is a null-pad CASE
# expression (`case when (#4) IS NULL then null else #0 end`). This is the case
# that once motivated a cost-model-native join commit path in eqsat.
#
# CURRENT BEHAVIOR: flag-on and flag-off produce the SAME plan. Both commit
# type=delta with t1 crossed on the t3-driven delta path
# (`%2 » %0:t1[×] » %1[#0]K`). The `enable_eqsat_native_join_commit` toggle no
# longer changes the plan. So this file is a DELEGATION-PARITY check: it pins
# that the eqsat physical pass matches the directional planner on the VOJ.
#
# WHERE THE ADVERTISED WIN WENT: an earlier native commit path chose a fully
# keyed DIFFERENTIAL order at raise time and avoided the cross. The
# delta-availability fix (commit 5fe2a40666) deleted eqsat's parallel join
# planner (best_left_deep_sequence, delta_join_order, frontier_key_cols, the
# whole join_commit.rs module) and routed commit_join through directional's
# plan_join_min_arrangements. So the physical plan is now whatever directional
# picks, which for this VOJ keeps the cross. The cross-avoidance was a property
# of the deleted native path, not of directional, and is not reachable at either
# flag setting today. `enable_eqsat_native_join_commit` is retained but inert on
# this shape.
#
# This is NOT a cross-avoidance win. Do not re-advertise it as one. The genuine
# eqsat wins live in test/sqllogictest/transform/eqsat_wins.slt.
# ============================================================================

simple conn=mz_system,user=mz_system
ALTER SYSTEM SET unsafe_enable_table_keys = true
----
COMPLETE 0

simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_eager_delta_joins = true
----
COMPLETE 0

statement ok
CREATE TABLE t1 (f0 int, f1 int)

statement ok
CREATE TABLE t2 (f2 int, f3 int)

statement ok
CREATE TABLE t3 (f4 int, f5 int)

# --- flag ON ---
simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_eqsat_delta_join_cost = true
----
COMPLETE 0

simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_eqsat_native_join_commit = true
----
COMPLETE 0

query T multiline
EXPLAIN OPTIMIZED PLAN WITH(join implementations) AS VERBOSE TEXT FOR
SELECT * FROM t1 LEFT JOIN t2 ON (f0 = f2) LEFT JOIN t3 ON (f2 = f4)
----
Explained Query:
  With
    cte l0 =
      Project (#0)
        ReadStorage materialize.public.t2
    cte l1 =
      Filter (#0) IS NOT NULL
        ReadStorage materialize.public.t3
  Return
    Project (#0, #1, #9, #10, #12, #13)
      Map ((#4) IS NULL, case when #8 then null else #0 end, case when #8 then null else #3 end, (#7) IS NULL, case when #11 then null else #5 end, case when #11 then null else #6 end)
        Join on=(#0 = #2 AND #5 = case when (#4) IS NULL then null else #0 end) type=delta
          implementation
            %0:t1 » %1[#0]K » %2[#0]K
            %1 » %0:t1[#0]K » %2[#0]K
            %2 » %0:t1[×] » %1[#0]K
          ArrangeBy keys=[[], [#0]]
            ReadStorage materialize.public.t1
          ArrangeBy keys=[[#0]]
            Union
              Filter (#0) IS NOT NULL
                Map (true)
                  ReadStorage materialize.public.t2
              Map (null, null)
                Threshold
                  Union
                    Negate
                      Filter (#0) IS NOT NULL
                        Get l0
                    Distinct project=[#0]
                      Union
                        Project (#0)
                          ReadStorage materialize.public.t1
                        Constant
                          - (null)
          ArrangeBy keys=[[#0]]
            Union
              Map (true)
                Get l1
              Map (null, null)
                Threshold
                  Union
                    Negate
                      Project (#0)
                        Get l1
                    Distinct project=[#0]
                      Union
                        Get l0
                        Constant
                          - (null)

Source materialize.public.t1
Source materialize.public.t2
Source materialize.public.t3
  filter=((#0) IS NOT NULL)

Target cluster: quickstart

EOF

# --- flag OFF ---
simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_eqsat_delta_join_cost = false
----
COMPLETE 0

simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_eqsat_native_join_commit = false
----
COMPLETE 0

query T multiline
EXPLAIN OPTIMIZED PLAN WITH(join implementations) AS VERBOSE TEXT FOR
SELECT * FROM t1 LEFT JOIN t2 ON (f0 = f2) LEFT JOIN t3 ON (f2 = f4)
----
Explained Query:
  With
    cte l0 =
      Project (#0)
        ReadStorage materialize.public.t2
    cte l1 =
      Filter (#0) IS NOT NULL
        ReadStorage materialize.public.t3
  Return
    Project (#0, #1, #9, #10, #12, #13)
      Map ((#4) IS NULL, case when #8 then null else #0 end, case when #8 then null else #3 end, (#7) IS NULL, case when #11 then null else #5 end, case when #11 then null else #6 end)
        Join on=(#0 = #2 AND #5 = case when (#4) IS NULL then null else #0 end) type=delta
          implementation
            %0:t1 » %1[#0]K » %2[#0]K
            %1 » %0:t1[#0]K » %2[#0]K
            %2 » %0:t1[×] » %1[#0]K
          ArrangeBy keys=[[], [#0]]
            ReadStorage materialize.public.t1
          ArrangeBy keys=[[#0]]
            Union
              Filter (#0) IS NOT NULL
                Map (true)
                  ReadStorage materialize.public.t2
              Map (null, null)
                Threshold
                  Union
                    Negate
                      Filter (#0) IS NOT NULL
                        Get l0
                    Distinct project=[#0]
                      Union
                        Project (#0)
                          ReadStorage materialize.public.t1
                        Constant
                          - (null)
          ArrangeBy keys=[[#0]]
            Union
              Map (true)
                Get l1
              Map (null, null)
                Threshold
                  Union
                    Negate
                      Project (#0)
                        Get l1
                    Distinct project=[#0]
                      Union
                        Get l0
                        Constant
                          - (null)

Source materialize.public.t1
Source materialize.public.t2
Source materialize.public.t3
  filter=((#0) IS NOT NULL)

Target cluster: quickstart

EOF
