mode cockroach

# ============================================================================
# eqsat_native_join_commit: cost-model-native join commit (SP-B1)
#
# This is the flagship variable-outer-join (VOJ) case: a chain of LEFT JOINs
# whose second join key is a null-pad CASE expression. Under the legacy delta
# planner it cross-products t1 on the t3-driven delta path.
#
# flag-ON  (enable_eqsat_physical_optimizer + enable_eqsat_delta_join_cost +
#           enable_eqsat_native_join_commit, all on):
#   The eqsat physical pass commits the join as a cost-model-chosen DIFFERENTIAL
#   plan at raise time (keyed-ness-primary order), so JoinImplementation no-ops
#   on it. The equivalences are run through the production canonicalizer first
#   (so the committed spelling, `else #0 end`, and the chosen order are stable
#   across build profiles). The resulting differential order is fully keyed:
#   NO cross (`[×]`) on any path.
#
# flag-OFF (enable_eqsat_native_join_commit=false):
#   Prior behavior, byte-identical: JoinImplementation delta-plans it as
#   type=delta with the t3 path crossing t1 (`%2 » %0:t1[×] » %1[#0]K`).
#
# So flag-on (differential, no cross) now DIFFERS from flag-off (delta cross) —
# the fix is live, not inert.
# ============================================================================

simple conn=mz_system,user=mz_system
ALTER SYSTEM SET unsafe_enable_table_keys = true
----
COMPLETE 0

simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_eager_delta_joins = true
----
COMPLETE 0

statement ok
CREATE TABLE t1 (f0 int, f1 int)

statement ok
CREATE TABLE t2 (f2 int, f3 int)

statement ok
CREATE TABLE t3 (f4 int, f5 int)

# --- flag ON ---
simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_eqsat_delta_join_cost = true
----
COMPLETE 0

simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_eqsat_native_join_commit = true
----
COMPLETE 0

query T multiline
EXPLAIN OPTIMIZED PLAN WITH(join implementations) AS VERBOSE TEXT FOR
SELECT * FROM t1 LEFT JOIN t2 ON (f0 = f2) LEFT JOIN t3 ON (f2 = f4)
----
Explained Query:
  With
    cte l0 =
      Filter (#0) IS NOT NULL
        ReadStorage materialize.public.t2
    cte l1 =
      Filter (#0) IS NOT NULL
        ReadStorage materialize.public.t3
  Return
    Project (#0, #1, #9, #10, #12, #13)
      Map ((#4) IS NULL, case when #8 then null else #0 end, case when #8 then null else #3 end, (#7) IS NULL, case when #11 then null else #5 end, case when #11 then null else #6 end)
        Join on=(#0 = #2 AND #5 = case when (#4) IS NULL then null else #0 end) type=differential
          implementation
            %1[#0] » %0:t1[#0] » %2[#0]
          ArrangeBy keys=[[#0]]
            ReadStorage materialize.public.t1
          ArrangeBy keys=[[#0]]
            Union
              Map (true)
                Get l0
              Map (null, null)
                Threshold
                  Union
                    Negate
                      Project (#0)
                        Get l0
                    Distinct project=[#0]
                      Union
                        Project (#0)
                          ReadStorage materialize.public.t1
                        Constant
                          - (null)
          ArrangeBy keys=[[#0]]
            Union
              Map (true)
                Get l1
              Map (null, null)
                Threshold
                  Union
                    Negate
                      Project (#0)
                        Get l1
                    Distinct project=[#0]
                      Union
                        Project (#0)
                          ReadStorage materialize.public.t2
                        Constant
                          - (null)

Source materialize.public.t1
Source materialize.public.t2
Source materialize.public.t3
  filter=((#0) IS NOT NULL)

Target cluster: quickstart

EOF

# --- flag OFF ---
simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_eqsat_delta_join_cost = false
----
COMPLETE 0

simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_eqsat_native_join_commit = false
----
COMPLETE 0

query T multiline
EXPLAIN OPTIMIZED PLAN WITH(join implementations) AS VERBOSE TEXT FOR
SELECT * FROM t1 LEFT JOIN t2 ON (f0 = f2) LEFT JOIN t3 ON (f2 = f4)
----
Explained Query:
  With
    cte l0 =
      Filter (#0) IS NOT NULL
        ReadStorage materialize.public.t2
    cte l1 =
      Filter (#0) IS NOT NULL
        ReadStorage materialize.public.t3
  Return
    Project (#0, #1, #9, #10, #12, #13)
      Map ((#4) IS NULL, case when #8 then null else #0 end, case when #8 then null else #3 end, (#7) IS NULL, case when #11 then null else #5 end, case when #11 then null else #6 end)
        Join on=(#0 = #2 AND #5 = case when (#4) IS NULL then null else #0 end) type=delta
          implementation
            %0:t1 » %1[#0]K » %2[#0]K
            %1 » %0:t1[#0]K » %2[#0]K
            %2 » %0:t1[×] » %1[#0]K
          ArrangeBy keys=[[], [#0]]
            ReadStorage materialize.public.t1
          ArrangeBy keys=[[#0]]
            Union
              Map (true)
                Get l0
              Map (null, null)
                Threshold
                  Union
                    Negate
                      Project (#0)
                        Get l0
                    Distinct project=[#0]
                      Union
                        Project (#0)
                          ReadStorage materialize.public.t1
                        Constant
                          - (null)
          ArrangeBy keys=[[#0]]
            Union
              Map (true)
                Get l1
              Map (null, null)
                Threshold
                  Union
                    Negate
                      Project (#0)
                        Get l1
                    Distinct project=[#0]
                      Union
                        Project (#0)
                          ReadStorage materialize.public.t2
                        Constant
                          - (null)

Source materialize.public.t1
Source materialize.public.t2
Source materialize.public.t3
  filter=((#0) IS NOT NULL)

Target cluster: quickstart

EOF
