mode cockroach

# Tests for EquivalencePropagation correctness.

statement ok
CREATE TABLE t (a int, b int, c int)

statement ok
INSERT INTO t VALUES (5, 1, 10), (5, 1, 20)

# Regression test for https://github.com/MaterializeInc/database-issues/issues/11282
#
# EquivalencePropagation's TopK handler must not push non-group-key column
# equivalences into the TopK's input.
#
# DISTINCT ON (b) picks the row with smallest c per group b=1.
# Candidates: (5,1,10), (5,1,20), (3,1,5); minimum c=5 belongs to (3,1,5) with a=3.
# So the outer WHERE a=5 should return 0 rows.
query III
SELECT * FROM (
    SELECT DISTINCT ON (b) a, b, c FROM (
        SELECT * FROM t UNION ALL VALUES (3, 1, 5)
    ) data ORDER BY b, c
) sub WHERE a = 5
----

statement ok
DROP TABLE t
