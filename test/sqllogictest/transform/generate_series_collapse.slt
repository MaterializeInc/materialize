# Its results agree with the regular function, including the explicit-step
# form and NULL bounds.

query I
SELECT count(*) FROM series_bounds8, mz_unsafe.generate_series_unoptimized(x, y, 2)
----
4

query I
SELECT count(*) FROM mz_unsafe.generate_series_unoptimized(1, NULL::bigint)
----
0

query I
SELECT sum(g) FROM series_bounds8, mz_unsafe.generate_series_unoptimized(x, y) g
----
