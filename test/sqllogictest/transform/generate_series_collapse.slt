# N7: mz_unsafe.generate_series_unoptimized never collapses, by contract —
# under exactly the count(*) shape that collapses the regular function (C1).

query T multiline
EXPLAIN OPTIMIZED PLAN AS VERBOSE TEXT FOR
SELECT count(*) FROM series_bounds8, mz_unsafe.generate_series_unoptimized(x, y)
----
Explained Query:
  With
    cte l0 =
      Reduce aggregates=[count(*)]
        Project ()
          FlatMap generate_series_unoptimized(#0{x}, #1{y}, 1)
            Project (#1, #2)
              ReadStorage materialize.public.series_bounds8
  Return
    Union
      Get l0
      Map (0)
        Union
          Negate
            Project ()
              Get l0
          Constant
            - ()

Source materialize.public.series_bounds8

Target cluster: quickstart

EOF

query I
SELECT count(*) FROM series_bounds8, mz_unsafe.generate_series_unoptimized(x, y)
----
