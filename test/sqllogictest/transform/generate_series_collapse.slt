# N3: a literal zero step is left in place, and errors at evaluation time just
# as generate_series does.

query error step size cannot equal zero
SELECT count(*) FROM series_bounds, generate_series(x, y, 0)

# N4: an all-literal series whose cardinality exceeds i64 declines to
# collapse; the plan keeps the enumerating generate_series. (Plan only: the
# series has ~10^19 elements, so we must not evaluate it.)

query T multiline
EXPLAIN OPTIMIZED PLAN AS VERBOSE TEXT FOR
SELECT count(*) FROM series_bounds, generate_series(-5000000000000000000, 5000000000000000000, 1)
----
Explained Query:
  With
    cte l0 =
      Reduce aggregates=[count(*)]
        CrossJoin type=differential
          ArrangeBy keys=[[]]
            Project ()
              FlatMap generate_series(-5000000000000000000, 5000000000000000000, 1)
                Constant
                  - ()
          ArrangeBy keys=[[]]
            Project ()
              ReadStorage materialize.public.series_bounds
  Return
    Union
      Get l0
      Map (0)
        Union
          Negate
            Project ()
              Get l0
          Constant
            - ()

Source materialize.public.series_bounds

Target cluster: quickstart

EOF

# N5: timestamp series are out of scope of the collapse. With column bounds
# the enumerating FlatMap remains.

statement ok
CREATE TABLE series_bounds_ts (k int, t1 timestamp, t2 timestamp)

statement ok
INSERT INTO series_bounds_ts VALUES
    (1, TIMESTAMP '2020-01-01 00:00:00', TIMESTAMP '2020-01-01 02:00:00')

query T multiline
EXPLAIN OPTIMIZED PLAN AS VERBOSE TEXT FOR
SELECT count(*) FROM series_bounds_ts, generate_series(t1, t2, INTERVAL '1 hour')
----
Explained Query:
  With
    cte l0 =
      Reduce aggregates=[count(*)]
        Project ()
          FlatMap generate_series(#0{t1}, #1{t2}, 01:00:00)
            Project (#1, #2)
              ReadStorage materialize.public.series_bounds_ts
  Return
    Union
      Get l0
      Map (0)
        Union
          Negate
            Project ()
              Get l0
          Constant
            - ()

Source materialize.public.series_bounds_ts

Target cluster: quickstart

EOF

query I
SELECT count(*) FROM series_bounds_ts, generate_series(t1, t2, INTERVAL '1 hour')
----
3

# (An all-literal timestamp series is evaluated outright by constant folding,
# so it needs no collapse.)

query I
SELECT count(*) FROM series_bounds,
    generate_series(TIMESTAMP '2020-01-01 00:00:00', TIMESTAMP '2020-01-01 02:00:00', INTERVAL '1 hour')
----
12

# N6: WITH ORDINALITY is out of scope, even when neither the value nor the
# ordinality is demanded.

query T multiline
EXPLAIN OPTIMIZED PLAN AS VERBOSE TEXT FOR
SELECT count(*) FROM series_bounds, generate_series(x, y) WITH ORDINALITY
----
Explained Query:
  With
    cte l0 =
      Reduce aggregates=[count(*)]
        Project ()
          FlatMap generate_series[with_ordinality](#0{x}, #1{y}, 1)
            Project (#1, #2)
              ReadStorage materialize.public.series_bounds
  Return
    Union
      Get l0
      Map (0)
        Union
          Negate
            Project ()
              Get l0
          Constant
            - ()

Source materialize.public.series_bounds

Target cluster: quickstart

EOF

query I
SELECT count(*) FROM series_bounds, generate_series(x, y) WITH ORDINALITY
----
