# Tests for the collapse of an unused `generate_series` into
# `repeat_row_non_negative` (ProjectionPushdown::collapse_unused_generate_series).
#
# When the values generated by an integer `generate_series` are not demanded,
# only its cardinality matters, and the FlatMap is rewritten to emit the same
# number of rows without materializing the series. This file articulates the
# boundary of that rewrite.
#
# COVERED — the FlatMap collapses (assertions: plan shape and results):
#   C1. int4 and int8 series whose output column is not demanded
#   C2. the two-argument form (implicit literal step 1) with column bounds
#   C3. a non-zero literal step, positive or negative, with column bounds
#   C4. all-literal arguments, folded to an exact literal count in i128;
#       this includes spans too wide for the i64 arithmetic of the
#       column-bounds path, as long as the resulting count fits in an i64
#   C5. NULL bounds (an empty series, exactly as generate_series treats them)
#
# NOT COVERED — the FlatMap remains a generate_series:
#   N1. the series value is genuinely demanded: in a predicate, or in a
#       value-dependent aggregate such as sum(g). Note that count(g) does NOT
#       prevent the collapse: the series column is non-nullable, so the
#       optimizer first rewrites count(g) to count(*), removing the demand.
#   N2. a non-literal step
#   N3. a literal zero step (left in place to error at evaluation time)
#   N4. all-literal series whose cardinality exceeds i64: the original
#       enumerates without error, so we decline rather than introduce one
#   N5. non-integer series (timestamps) with column bounds. (All-literal
#       timestamp series disappear anyway: constant folding evaluates them.)
#   N6. WITH ORDINALITY
#   N7. mz_unsafe.generate_series_unoptimized — BY CONTRACT. The optimizer
#       promises to never replace its evaluation with a cardinality shortcut,
#       so tests can rely on the enumeration work actually happening. Not a
#       supported surface; bug reports must not depend on it.

mode cockroach

statement ok
CREATE TABLE series_bounds (k int, x int, y int)

statement ok
INSERT INTO series_bounds VALUES (1, 1, 3), (2, 5, 4), (3, 2, NULL), (4, 10, 12)

statement ok
CREATE TABLE series_bounds8 (k int, x bigint, y bigint)

statement ok
INSERT INTO series_bounds8 VALUES (1, 1, 3), (2, 5, 4), (3, 2, NULL), (4, 10, 12)

# C1/C2: two-argument form over int4 column bounds collapses (with widening
# casts); rows contribute floor((y - x) / 1) + 1 rows when y >= x, else none,
# and NULL bounds contribute none.

query T multiline
EXPLAIN OPTIMIZED PLAN AS VERBOSE TEXT FOR
SELECT count(*) FROM series_bounds, generate_series(x, y)
----
Explained Query:
  With
    cte l0 =
      Reduce aggregates=[count(*)]
        Project ()
          FlatMap repeat_row_non_negative(case when (#1{y} >= #0{x}) then ((integer_to_bigint(#1{y}) - integer_to_bigint(#0{x})) + 1) else 0 end)
            Project (#1, #2)
              ReadStorage materialize.public.series_bounds
  Return
    Union
      Get l0
      Map (0)
        Union
          Negate
            Project ()
              Get l0
          Constant
            - ()

Source materialize.public.series_bounds

Target cluster: quickstart

EOF

query I
SELECT count(*) FROM series_bounds, generate_series(x, y)
----
6

query II
SELECT k, count(*) FROM series_bounds, generate_series(x, y) GROUP BY k ORDER BY k
----
1  3
4  3

# C1: int8 column bounds collapse without casts.

query T multiline
EXPLAIN OPTIMIZED PLAN AS VERBOSE TEXT FOR
SELECT count(*) FROM series_bounds8, generate_series(x, y)
----
Explained Query:
  With
    cte l0 =
      Reduce aggregates=[count(*)]
        Project ()
          FlatMap repeat_row_non_negative(case when (#1{y} >= #0{x}) then ((#1{y} - #0{x}) + 1) else 0 end)
            Project (#1, #2)
              ReadStorage materialize.public.series_bounds8
  Return
    Union
      Get l0
      Map (0)
        Union
          Negate
            Project ()
              Get l0
          Constant
            - ()

Source materialize.public.series_bounds8

Target cluster: quickstart

EOF

query I
SELECT count(*) FROM series_bounds8, generate_series(x, y)
----
6

# The collapsed plan agrees with the uncollapsed one: counting the series
# values themselves (which demands them; see N1) gives the same answer.

query I
SELECT count(g) FROM series_bounds, generate_series(x, y) g
----
6

# Aggregates that ignore the series values still see the right multiplicities.

query IIIRI
SELECT sum(k), min(k), max(k), avg(k), count(DISTINCT k)
FROM series_bounds, generate_series(x, y)
----
15  1  4  2.5  2

# C3: non-unit positive literal step.

query T multiline
EXPLAIN OPTIMIZED PLAN AS VERBOSE TEXT FOR
SELECT count(*) FROM series_bounds, generate_series(x, y, 2)
----
Explained Query:
  With
    cte l0 =
      Reduce aggregates=[count(*)]
        Project ()
          FlatMap repeat_row_non_negative(case when (#1{y} >= #0{x}) then numeric_to_bigint((floornumeric(((integer_to_numeric(#1{y}) - integer_to_numeric(#0{x})) / 2)) + 1)) else 0 end)
            Project (#1, #2)
              ReadStorage materialize.public.series_bounds
  Return
    Union
      Get l0
      Map (0)
        Union
          Negate
            Project ()
              Get l0
          Constant
            - ()

Source materialize.public.series_bounds

Target cluster: quickstart

EOF

query I
SELECT count(*) FROM series_bounds, generate_series(x, y, 2)
----
4

# C3: negative literal step (descending series; the emptiness guard flips).

query I
SELECT count(*) FROM series_bounds, generate_series(y, x, -1)
----
6

# C3: the column-bounds path handles a span too wide for i64 too. A coarse step
# over near-opposite int8 extremes is a *feasible* series (here six rows) whose
# span exceeds 2^63, so with a unit step the synthesized i64 arithmetic would be
# fine only for infeasible series; with a larger step it must not overflow. We
# do the arithmetic in numeric, so this counts correctly rather than erroring
# (regression test: this query previously failed with "numeric field overflow").

statement ok
CREATE TABLE wide_bounds (lo bigint, hi bigint)

statement ok
INSERT INTO wide_bounds VALUES (-5000000000000000000, 5000000000000000000)

query T multiline
EXPLAIN OPTIMIZED PLAN AS VERBOSE TEXT FOR
SELECT count(*) FROM wide_bounds, generate_series(lo, hi, 2000000000000000000)
----
Explained Query:
  With
    cte l0 =
      Reduce aggregates=[count(*)]
        Project ()
          FlatMap repeat_row_non_negative(case when (#1{hi} >= #0{lo}) then numeric_to_bigint((floornumeric(((bigint_to_numeric(#1{hi}) - bigint_to_numeric(#0{lo})) / 2000000000000000000)) + 1)) else 0 end)
            ReadStorage materialize.public.wide_bounds
  Return
    Union
      Get l0
      Map (0)
        Union
          Negate
            Project ()
              Get l0
          Constant
            - ()

Source materialize.public.wide_bounds

Target cluster: quickstart

EOF

query I
SELECT count(*) FROM wide_bounds, generate_series(lo, hi, 2000000000000000000)
----
6

# C4: all-literal arguments fold to an exact literal count.

query T multiline
EXPLAIN OPTIMIZED PLAN AS VERBOSE TEXT FOR
SELECT count(*) FROM series_bounds, generate_series(2, 11, 3)
----
Explained Query:
  With
    cte l0 =
      Reduce aggregates=[count(*)]
        CrossJoin type=differential
          ArrangeBy keys=[[]]
            Project ()
              ReadStorage materialize.public.series_bounds
          ArrangeBy keys=[[]]
            Constant
              - (() x 4)
  Return
    Union
      Get l0
      Map (0)
        Union
          Negate
            Project ()
              Get l0
          Constant
            - ()

Source materialize.public.series_bounds

Target cluster: quickstart

EOF

query I
SELECT count(*) FROM series_bounds, generate_series(2, 11, 3)
----
16

query I
SELECT count(*) FROM series_bounds, generate_series(11, 2, -3)
----
16

# C4: an all-literal empty series folds to a count of zero.

query I
SELECT count(*) FROM series_bounds, generate_series(11, 2, 3)
----
0

# C4: a literal span too wide for i64 arithmetic still folds exactly when the
# count fits: 10^19 / 10^18 + 1 = 11. The literal path computes this in i128 at
# rewrite time (the column-bounds path would reach for numeric; see C3 above).

query I
SELECT count(*) FROM generate_series(-5000000000000000000, 5000000000000000000, 1000000000000000000)
----
11

# C5: NULL bounds produce an empty series, as in generate_series itself.

query I
SELECT count(*) FROM generate_series(1, NULL::int)
----
0

# A series large enough to defeat constant folding still counts in O(1)
# through the rendered dataflow.

query I
SELECT count(*) FROM series_bounds, generate_series(1, 1000000)
----
4000000

# Counting the series column itself still collapses: g is non-nullable, so
# count(g) is first rewritten to count(*), which removes the demand.

query T multiline
EXPLAIN OPTIMIZED PLAN AS VERBOSE TEXT FOR
SELECT count(g) FROM series_bounds, generate_series(x, y) g
----
Explained Query:
  With
    cte l0 =
      Reduce aggregates=[count(*)]
        Project ()
          FlatMap repeat_row_non_negative(case when (#1{y} >= #0{x}) then ((integer_to_bigint(#1{y}) - integer_to_bigint(#0{x})) + 1) else 0 end)
            Project (#1, #2)
              ReadStorage materialize.public.series_bounds
  Return
    Union
      Get l0
      Map (0)
        Union
          Negate
            Project ()
              Get l0
          Constant
            - ()

Source materialize.public.series_bounds

Target cluster: quickstart

EOF

# N1: a genuinely value-dependent demand prevents the collapse: in a
# value-sensitive aggregate...

query T multiline
EXPLAIN OPTIMIZED PLAN AS VERBOSE TEXT FOR
SELECT sum(g) FROM series_bounds, generate_series(x, y) g
----
Explained Query:
  With
    cte l0 =
      Reduce aggregates=[sum(#0{g})]
        Project (#2)
          FlatMap generate_series(#0{x}, #1{y}, 1)
            Project (#1, #2)
              ReadStorage materialize.public.series_bounds
  Return
    Union
      Get l0
      Map (null)
        Union
          Negate
            Project ()
              Get l0
          Constant
            - ()

Source materialize.public.series_bounds

Target cluster: quickstart

EOF

# ...or in a predicate.

query T multiline
EXPLAIN OPTIMIZED PLAN AS VERBOSE TEXT FOR
SELECT count(*) FROM series_bounds, generate_series(x, y) g WHERE g > 1
----
Explained Query:
  With
    cte l0 =
      Reduce aggregates=[count(*)]
        Project ()
          Filter (#2{g} > 1)
            FlatMap generate_series(#0{x}, #1{y}, 1)
              Project (#1, #2)
                ReadStorage materialize.public.series_bounds
  Return
    Union
      Get l0
      Map (0)
        Union
          Negate
            Project ()
              Get l0
          Constant
            - ()

Source materialize.public.series_bounds

Target cluster: quickstart

EOF

query I
SELECT count(*) FROM series_bounds, generate_series(x, y) g WHERE g > 1
----
5

query I
SELECT sum(g) FROM series_bounds, generate_series(x, y) g
----
39

# N2: a non-literal step prevents the collapse.

query T multiline
EXPLAIN OPTIMIZED PLAN AS VERBOSE TEXT FOR
